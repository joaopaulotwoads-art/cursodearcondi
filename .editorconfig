# https://editorconfig.org — evita corrupção de acentos (UTF-8) e mistura CRLF/LF
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{mdoc,md,mdx}]
charset = utf-8
end_of_line = lf

[*.{json,yml,yaml}]
charset = utf-8
end_of_line = lf

[*.bat]
end_of_line = crlf
