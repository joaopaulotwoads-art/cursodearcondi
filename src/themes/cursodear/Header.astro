---
import type { NavItem } from './types';

interface Props {
  siteName: string;
  nav: NavItem[];
  logoSrc?: string;
}

const { siteName, nav, logoSrc } = Astro.props;
---
<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 shadow-sm backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <div class="flex items-center gap-3">
      <img src={logoSrc || '/logo.png'} alt="Curso de Ar Condicionado" class="h-10 w-auto object-contain" />
      <div class="hidden md:block">
        <p class="text-sm font-black leading-tight text-slate-800">CURSO DE AR CONDICIONADO</p>
        <p class="text-xs font-medium text-orange-500">Formação Profissional em Climatização</p>
      </div>
    </div>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegação institucional">
      <a href="/" class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">Início</a>
      <a href="/cursos" class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">Nossos Cursos</a>
      <a href="/sobre" class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">Sobre</a>
      <a href="/blog" class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">Blog</a>
      <a href="/contato" class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">Contato</a>
    </nav>

    <button type="button" id="bem-mobile-menu-btn" class="p-2 text-gray-600 md:hidden" aria-label="Abrir menu">
      ☰
    </button>
  </div>
  <div id="bem-mobile-menu" class="absolute left-0 right-0 top-16 hidden border-b border-gray-200 bg-white px-6 py-4 shadow-lg md:hidden">
    <nav class="flex flex-col gap-4">
      <a href="/" class="bem-mobile-nav-link border-b border-gray-100 py-2 font-medium text-gray-700">Início</a>
      <a href="/cursos" class="bem-mobile-nav-link border-b border-gray-100 py-2 font-medium text-gray-700">Nossos Cursos</a>
      <a href="/sobre" class="bem-mobile-nav-link border-b border-gray-100 py-2 font-medium text-gray-700">Sobre</a>
      <a href="/blog" class="bem-mobile-nav-link border-b border-gray-100 py-2 font-medium text-gray-700">Blog</a>
      <a href="/contato" class="bem-mobile-nav-link border-b border-gray-100 py-2 font-medium text-gray-700">Contato</a>
    </nav>
  </div>
</header>
<script>
  document.getElementById('bem-mobile-menu-btn')?.addEventListener('click', () => document.getElementById('bem-mobile-menu')?.classList.toggle('hidden'));
  document.querySelectorAll('.bem-mobile-nav-link').forEach((link) => link.addEventListener('click', () => document.getElementById('bem-mobile-menu')?.classList.add('hidden')));
</script>
