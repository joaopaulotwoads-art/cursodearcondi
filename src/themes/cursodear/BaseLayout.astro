---
import Header from './Header.astro';
import Footer from './Footer.astro';
import type { NavItem } from './types';
/** Open Sans — corpo e títulos (tipografia editorial legível, alinhada a Tailwind `font-sans` / `font-heading`) */
import '@fontsource/open-sans/400.css';
import '@fontsource/open-sans/500.css';
import '@fontsource/open-sans/600.css';
import '@fontsource/open-sans/700.css';
import '@fontsource/open-sans/800.css';
import './global.css';
import { ensureApexSiteOrigin } from '../../utils/read-site-settings';
import { buildcursodearDefaultSiteJsonLd } from '../../utils/post-json-ld';
import FaviconLinks from '../../components/FaviconLinks.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  siteName: string;
  /** Caminho público do logo (ex.: /cursodear-logo.png) quando definido no singleton Menu. */
  logoSrc?: string;
  siteUrl: string;
  nav: NavItem[];
  footerNav: NavItem[];
  /** Singletons do rodapé (ex.: cursodear) */
  contentThemeId?: string;
  ogType?: 'website' | 'article';
  ogImageAbs?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  extraJsonLd?: Record<string, unknown> | null;
  canonicalOverride?: string;
  robots?: string;
  showFooter?: boolean;
}

const {
  title,
  description,
  canonical,
  keywords,
  siteName,
  logoSrc,
  siteUrl,
  nav,
  footerNav,
  contentThemeId = 'cursodear',
  ogType = 'website',
  ogImageAbs,
  articlePublishedTime,
  articleModifiedTime,
  extraJsonLd,
  canonicalOverride,
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  showFooter = true,
} = Astro.props;
/** Título do documento: o que cada página passa em `title` (sem sufixo automático | marca). */
const fullTitle = title;
const fullDescription = description || '';
const metaKeywords = keywords || '';
const siteOrigin = ensureApexSiteOrigin(siteUrl);
const path = Astro.url.pathname;
const canonicalPath = path.endsWith('/') ? path : `${path}/`;
const canonicalPageUrl =
  canonical || canonicalOverride || `https://cursodearcondicionado.com.br${canonicalPath}`;
/** Um único JSON-LD: post traz @graph completo; demais páginas usam WebSite + Organization + SearchAction */
const jsonLdGraph = extraJsonLd ?? buildcursodearDefaultSiteJsonLd({
    siteUrl: siteOrigin || siteUrl,
    siteName,
    description: fullDescription || undefined,
});
---
<!DOCTYPE html>
<html lang="pt-BR" class="cursodear-root overflow-x-hidden">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {ogType === 'article' && (
    <link rel="preconnect" href="https://m.media-amazon.com" crossorigin />
  )}
  <FaviconLinks />
  <meta name="theme-color" content="#faf7f5" />
  <title>{fullTitle}</title>
  <meta name="description" content={fullDescription} />
  {metaKeywords && <meta name="keywords" content={metaKeywords} />}
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalPageUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={fullDescription} />
  <meta property="og:url" content={canonicalPageUrl} />
  <meta property="og:locale" content="pt_BR" />
  {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}
  <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={fullDescription} />
  {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
  <style is:global>
    html {
      scroll-padding-top: 80px;
    }
  </style>
</head>
<body class="cursodear-scope min-w-0 overflow-x-hidden bg-[var(--color-bg)] text-[var(--color-text)] antialiased">
  <Header siteName={siteName} logoSrc={logoSrc} nav={nav} />
  <main class="min-w-0"><slot /></main>
  {showFooter && <Footer siteName={siteName} logoSrc={logoSrc} footerNav={footerNav} contentThemeId={contentThemeId} />}
</body>
</html>
