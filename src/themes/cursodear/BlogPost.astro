---
import type { CollectionEntry } from 'astro:content';
import PostArticleToc from '../../components/cursodear/PostArticleToc.astro';
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { resolvecursodearMediaUrl, rewritecursodearContentImagesInHtml } from '../../utils/media-url';
import { demoteBodyH1ToH2, replaceProductBoxTitleH2WithDiv } from '../../utils/post-html-sanitize';
import { splitReviewRoundupBodyParagraphs } from '../../utils/review-paragraph-split';
import { buildMarkdownToc, POST_TOC_MIN_ITEMS, type PostTocItem } from '../../utils/post-markdown-toc';
import { readPost } from '../../utils/post-utils';
import { injectH2IdsAndBuildToc, splitHtmlAfterReviewHeroPicks } from '../../utils/review-article-toc';
import { injectMissingProsConsCtas } from '../../utils/review-pros-cons-cta';
import { ensureRoundupTableHead, upgradeRoundupItemsHtml } from '../../utils/review-roundup-rows';
import '../../styles/post-article-toc.css';

interface Props {
  post: any;
  author: any;
  Content?: any;
  /** Corpo HTML (import Ghost / contentFormat: html); ignora Content. */
  htmlContent?: string | null;
  relatedPosts?: CollectionEntry<'posts'>[];
  blogPermalinkStructure?: BlogPermalinkStructure;
  blogUrlPrefix?: BlogUrlPrefix;
}

const {
  post,
  author,
  Content,
  htmlContent,
  relatedPosts: relatedPostsProp,
  blogPermalinkStructure = 'postname',
  blogUrlPrefix = 'blog',
} = Astro.props;
const relatedPosts = relatedPostsProp ?? [];
const date = post.data.publishedDate;
const layoutVariant = post.data.articleLayout ?? 'default';
const isReviewRoundup = layoutVariant === 'reviewRoundup';
const heroImage = resolvecursodearMediaUrl(post.data.thumbnail || post.data.image);
const htmlBody = htmlContent
  ? (() => {
      let html = demoteBodyH1ToH2(rewritecursodearContentImagesInHtml(htmlContent));
      html = replaceProductBoxTitleH2WithDiv(html);
      if (isReviewRoundup) html = splitReviewRoundupBodyParagraphs(html);
      return html;
    })()
  : null;

let postHtmlBody = htmlBody;
let reviewTocItems: { id: string; text: string }[] = [];
let reviewBodySplit: { head: string; tail: string } | null = null;
if (htmlBody && htmlBody.includes('cnx-aff-roundup')) {
  let h = upgradeRoundupItemsHtml(htmlBody);
  h = ensureRoundupTableHead(h);
  postHtmlBody = h;
}
if (isReviewRoundup && postHtmlBody) {
  const tocResult = injectH2IdsAndBuildToc(postHtmlBody);
  postHtmlBody = injectMissingProsConsCtas(tocResult.html);
  reviewTocItems = tocResult.toc;
  reviewBodySplit = splitHtmlAfterReviewHeroPicks(postHtmlBody);
} else if (postHtmlBody) {
  const tocResult = injectH2IdsAndBuildToc(postHtmlBody);
  postHtmlBody = tocResult.html;
  reviewTocItems = tocResult.toc;
}

const postSlug = post.data.slug || post.id;
let markdownTocItems: PostTocItem[] = [];
if (!htmlContent && Content) {
  const postFile = await readPost(postSlug);
  if (postFile?.content) {
    const parsed = buildMarkdownToc(postFile.content);
    markdownTocItems = parsed.length >= POST_TOC_MIN_ITEMS ? parsed : [];
  }
}

const articleTocItems: PostTocItem[] = markdownTocItems.length
  ? markdownTocItems
  : reviewTocItems.map((item) => ({ ...item, level: 2 as const }));
const showArticleToc = articleTocItems.length >= POST_TOC_MIN_ITEMS;

/**
 * Cartão de produto, prós/contras e títulos de review usam CSS em article-review-roundup.css
 * sob o ancestral `.article-review-roundup`. Antes só existia em posts com layout "reviewRoundup",
 * por isso o mesmo HTML no layout default parecia "versão antiga" (só o ranking parecia certo).
 */
const applyRoundupArticleScope =
  isReviewRoundup || (!!postHtmlBody && /\bcnx-aff-/.test(postHtmlBody));
---
<article
  class:list={[
    'mx-auto py-10 sm:py-12',
    applyRoundupArticleScope ? 'px-4 sm:px-5 max-w-4xl article-review-roundup' : 'px-4 sm:px-5',
    !applyRoundupArticleScope && (htmlContent ? 'max-w-3xl' : 'max-w-2xl'),
  ]}
>
  <header class:list={[isReviewRoundup ? 'mb-5 md:mb-6' : 'mb-8 md:mb-10']}>
    <nav class="text-sm text-[var(--color-muted)] mb-3 md:mb-3.5 leading-snug" aria-label="Navegação do artigo">
      <a href="/" class="text-[var(--color-muted)] hover:text-[var(--color-link)] no-underline transition-colors">Início</a>
      <span class="mx-1.5 opacity-60 select-none" aria-hidden="true">›</span>
      <span class="text-[var(--color-dark)] font-medium">{post.data.title}</span>
    </nav>
    <h1
      class="text-3xl sm:text-[2rem] md:text-[2.125rem] font-extrabold tracking-tight text-[var(--color-heading)] leading-[1.2] [font-family:var(--font-heading)]"
    >
      {post.data.title}
    </h1>
  </header>
  {heroImage && (
    <div
      class:list={[
        'post-hero-image-wrap flex items-center justify-center',
        isReviewRoundup ? 'mb-5 md:mb-6' : 'mb-8',
      ]}
    >
      <img
        src={heroImage}
        alt={post.data.imageAlt || post.data.title}
        width={900}
        height={600}
        class="post-hero-image"
        sizes="(max-width: 896px) 100vw, 832px"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  )}
  {(author || date) && (
    <div
      class:list={[
        'flex items-start gap-3 sm:gap-3.5',
        isReviewRoundup ? 'mb-6 md:mb-7 pb-6 md:pb-7 border-b border-orange-200/70' : 'mb-8 md:mb-10',
      ]}
    >
      {author ? (
        <>
          {author.data.avatar ? (
            <img
              src={resolvecursodearMediaUrl(author.data.avatar)}
              alt=""
              width="48"
              height="48"
              class="w-11 h-11 sm:w-12 sm:h-12 rounded-full object-cover shrink-0 border border-[var(--color-border)] bg-white"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div
              class="w-11 h-11 sm:w-12 sm:h-12 rounded-full shrink-0 flex items-center justify-center text-sm font-semibold text-[var(--color-heading)] bg-[var(--color-surface)] border border-[var(--color-border)]"
              aria-hidden="true"
            >
              {String(author.data.name || '?')
                .trim()
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
          <div class="min-w-0 pt-0.5">
            <div class="font-bold text-[var(--color-heading)] text-base sm:text-[1.0625rem] leading-snug">{author.data.name}</div>
            {date && (
              <time class="mt-1 block text-sm text-[var(--color-muted)]" datetime={date}>
                {new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
              </time>
            )}
          </div>
        </>
      ) : (
        date && (
          <time class="text-sm text-[var(--color-muted)]" datetime={date}>
            {new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' })}
          </time>
        )
      )}
    </div>
  )}
  <div
    class:list={[
      'post-content max-w-none text-[var(--color-dark)]',
      !htmlContent &&
        'prose prose-neutral prose-lg max-w-none prose-p:text-[18px] prose-p:leading-[1.6] prose-p:mb-[1.25em] prose-p:text-[var(--color-dark)] prose-headings:[font-family:var(--font-heading)] prose-headings:font-bold prose-headings:text-[var(--color-heading)] prose-h1:text-3xl prose-h1:tracking-tight prose-h2:text-2xl prose-h2:tracking-tight prose-h2:mt-6 prose-h2:mb-3 prose-h3:text-xl prose-h3:tracking-tight prose-h3:mt-6 prose-h3:mb-3 prose-h4:text-lg prose-h4:mt-6 prose-h4:mb-3 prose-h5:text-base prose-h5:font-semibold prose-h5:mt-6 prose-h5:mb-3 prose-h6:text-[0.8125rem] prose-h6:uppercase prose-h6:tracking-wide prose-h6:font-semibold prose-h6:text-[#64748b] prose-h6:mt-6 prose-h6:mb-3 prose-li:my-2 prose-a:font-medium prose-a:text-[var(--color-link)] prose-a:underline hover:prose-a:text-[var(--color-link-hover)] prose-img:my-8 prose-img:w-full prose-img:max-w-full prose-img:rounded-2xl prose-img:border prose-img:border-[var(--color-border)]',
    ]}
  >
    {postHtmlBody ? (
      isReviewRoundup && reviewBodySplit ? (
        <>
          {reviewBodySplit.head ? <div class="cursodear-post-html post-content" set:html={reviewBodySplit.head} /> : null}
          {showArticleToc && <PostArticleToc items={articleTocItems} />}
          <div class="cursodear-post-html post-content" set:html={reviewBodySplit.tail} />
        </>
      ) : (
        <>
          {showArticleToc && <PostArticleToc items={articleTocItems} />}
          <div class="cursodear-post-html post-content" set:html={postHtmlBody} />
        </>
      )
    ) : (
      Content && (
        <div class="post-content-with-toc" data-post-toc>
          {showArticleToc && (
            <>
              <script
                type="application/json"
                id="post-toc-data"
                set:html={JSON.stringify(articleTocItems)}
              />
              <PostArticleToc items={articleTocItems} />
            </>
          )}
          <Content />
        </div>
      )
    )}
  </div>

  {markdownTocItems.length > 0 && (
    <script is:inline>
      {`function applyPostMarkdownToc(){var dataEl=document.getElementById("post-toc-data");var root=document.querySelector("[data-post-toc]");if(!dataEl||!root)return;var items=[];try{items=JSON.parse(dataEl.textContent||"[]")}catch(e){return}var headings=root.querySelectorAll("h2,h3");items.forEach(function(item,idx){var h=headings[idx];if(h)h.id=item.id});var tocPanel=root.querySelector(".post-article-toc");var firstH2=root.querySelector("h2");if(tocPanel&&firstH2)firstH2.before(tocPanel)}applyPostMarkdownToc();document.addEventListener("astro:page-load",applyPostMarkdownToc);`}
    </script>
  )}

  {author && (
    <section
      class="post-author-section mt-12 pt-10 border-t border-[var(--color-border)]"
      aria-labelledby="post-author-heading"
    >
      <div
        class="post-author-card relative left-1/2 w-[min(56rem,calc(100vw-2rem))] max-w-4xl -translate-x-1/2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-8 lg:p-10"
      >
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-[5.5rem_1fr] sm:gap-x-6 sm:gap-y-4">
          {author.data.avatar ? (
            <img
              src={resolvecursodearMediaUrl(author.data.avatar)}
              alt={author.data.name}
              width="96"
              height="96"
              class="w-20 h-20 sm:w-[5.5rem] sm:h-[5.5rem] rounded-full object-cover shrink-0 ring-2 ring-gray-200 border border-[var(--color-border)] sm:row-span-1"
              loading="lazy"
            />
          ) : (
            <div
              class="w-20 h-20 sm:w-[5.5rem] sm:h-[5.5rem] rounded-full shrink-0 flex items-center justify-center text-xl sm:text-2xl font-semibold text-[var(--color-heading)] bg-white border border-[var(--color-border)] ring-2 ring-gray-200 sm:row-span-1"
              aria-hidden="true"
            >
              {String(author.data.name || '?')
                .trim()
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
          <div class="min-w-0 sm:pt-1">
            <div id="post-author-heading" class="text-xl font-semibold text-[var(--color-heading)] md:text-[1.35rem]">
              {author.data.name}
            </div>
            {author.data.role && (
              <p class="mt-1.5 text-sm font-medium text-[var(--color-heading)] md:text-base">{author.data.role}</p>
            )}
          </div>
          {author.data.bio && (
            <p class="sm:col-span-2 text-[var(--color-muted)] text-[17px] leading-[1.65] md:text-[18px] md:leading-[1.7]">
              {author.data.bio}
            </p>
          )}
          <a
            href={author.data.profilePath || `/authors/${author.id}`}
            class="sm:col-span-2 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-link)] no-underline hover:underline min-h-[44px]"
          >
            Ver perfil completo
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  )}

  {relatedPosts.length > 0 && (
    <section
      class:list={[
        'mt-12 pt-10 border-t',
        isReviewRoundup ? 'border-orange-200/80' : 'border-[var(--color-border)]',
      ]}
      aria-labelledby="related-posts-heading"
    >
      <h2
        id="related-posts-heading"
        class="text-xl font-extrabold tracking-tight text-[var(--color-heading)] [font-family:var(--font-heading)]"
      >
        Posts relacionados
      </h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 mt-6">
        {relatedPosts.map((rp) => {
          const url = getPostUrl(rp, blogPermalinkStructure, blogUrlPrefix);
          const thumb = resolvecursodearMediaUrl(rp.data.thumbnail || rp.data.metaImage);
          const rDate = rp.data.publishedDate;
          return (
            <a
              href={url}
              class="group block rounded-lg border border-[var(--color-border)] bg-white overflow-hidden hover:border-[var(--color-link)] transition-colors shadow-sm"
            >
              {thumb ? (
                <div class="aspect-[4/3] overflow-hidden bg-[var(--color-surface)]">
                  <img
                    src={thumb}
                    alt=""
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="aspect-[4/3] bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-muted)] text-sm">
                  Sem capa
                </div>
              )}
              <div class="p-4">
                {rDate && (
                  <time class="text-xs text-[var(--color-muted)]" datetime={rDate}>
                    {new Date(rDate).toLocaleDateString('pt-BR')}
                  </time>
                )}
                <h3 class="mt-1 text-base font-semibold text-[var(--color-heading)] group-hover:text-[var(--color-link)] leading-snug">
                  {rp.data.title}
                </h3>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}
</article>
