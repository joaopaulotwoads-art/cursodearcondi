---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<article class="max-w-2xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-extrabold tracking-tight text-[var(--color-heading)] mb-8 md:text-4xl">{title}</h1>
  <div
    class="prose prose-neutral max-w-none text-[var(--color-text)] prose-p:text-[18px] prose-p:leading-relaxed prose-headings:text-[var(--color-heading)] prose-a:font-medium prose-a:text-[var(--color-link)] prose-a:no-underline hover:prose-a:underline"
  >
    <slot />
  </div>
</article>
