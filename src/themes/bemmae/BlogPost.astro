---
import { resolveBemmaeMediaUrl, rewriteBemmaeContentImagesInHtml } from '../../utils/media-url';
import { demoteBodyH1ToH2 } from '../../utils/post-html-sanitize';
import { expandPostHtmlComponents } from '../../utils/post-html-components';

interface Props {
  post: any;
  author: any;
  Content?: any;
  /** Corpo HTML (import Ghost / contentFormat: html); ignora Content. */
  htmlContent?: string | null;
}

const { post, author, Content, htmlContent } = Astro.props;
const date = post.data.publishedDate;
const heroImage = resolveBemmaeMediaUrl(post.data.thumbnail || post.data.metaImage);
const htmlBody = htmlContent
  ? expandPostHtmlComponents(demoteBodyH1ToH2(rewriteBemmaeContentImagesInHtml(htmlContent)))
  : null;
---
<article class:list={['mx-auto px-4 sm:px-5 py-10 sm:py-12', htmlContent ? 'max-w-3xl' : 'max-w-2xl']}>
  <header class="mb-8">
    <a
      href="/blog"
      class="text-sm font-medium text-[var(--color-link)] no-underline hover:underline mb-4 inline-block"
    >
      ← Blog
    </a>
    <h1 class="text-3xl font-extrabold tracking-tight text-[var(--color-heading)] md:text-4xl">{post.data.title}</h1>
    <div class="mt-3 flex flex-wrap gap-4 text-sm text-[var(--color-muted)]">
      {date && (
        <time datetime={date}>{new Date(date).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
      )}
      {author && <span>{author.data.name}</span>}
    </div>
  </header>
  {heroImage && (
    <div class="rounded-lg overflow-hidden mb-8">
      <img
        src={heroImage}
        alt=""
        width={900}
        height={600}
        class="w-full h-auto object-cover max-h-[420px]"
        sizes="(max-width: 896px) 100vw, 832px"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  )}
  <div
    class:list={[
      'max-w-none text-[var(--color-text)]',
      !htmlContent &&
        'prose prose-neutral prose-lg max-w-none prose-p:text-[18px] prose-p:leading-[1.75] prose-p:mb-[1.25em] prose-p:text-[var(--color-text)] prose-headings:text-[var(--color-heading)] prose-headings:font-bold prose-h2:text-2xl prose-h2:tracking-tight prose-h2:mt-10 prose-h2:mb-4 prose-h3:mt-8 prose-h3:mb-3 prose-li:my-2 prose-a:font-medium prose-a:text-[var(--color-link)] prose-a:no-underline hover:prose-a:underline',
    ]}
  >
    {htmlBody ? (
      <div class="bemmae-post-html" set:html={htmlBody} />
    ) : (
      Content && <Content />
    )}
  </div>

  {author && (
    <section class="mt-12 pt-10 border-t border-[var(--color-border)]" aria-labelledby="post-author-heading">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-8">
        <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 items-start">
          {author.data.avatar ? (
            <img
              src={resolveBemmaeMediaUrl(author.data.avatar)}
              alt={author.data.name}
              width="96"
              height="96"
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover shrink-0 ring-2 ring-gray-200 border border-[var(--color-border)]"
              loading="lazy"
            />
          ) : (
            <div
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-full shrink-0 flex items-center justify-center text-xl sm:text-2xl font-semibold text-[var(--color-heading)] bg-white border border-[var(--color-border)] ring-2 ring-gray-200"
              aria-hidden="true"
            >
              {String(author.data.name || '?')
                .trim()
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted)] mb-1">Sobre quem escreveu</p>
            <div id="post-author-heading" class="text-xl font-semibold text-[var(--color-heading)]">
              {author.data.name}
            </div>
            {author.data.role && (
              <p class="mt-1 text-sm font-medium text-[var(--color-muted)]">{author.data.role}</p>
            )}
            {author.data.bio && (
              <p class="mt-4 text-[var(--color-muted)] leading-relaxed text-[0.98rem]">{author.data.bio}</p>
            )}
            <a
              href={`/authors/${author.id}`}
              class="inline-flex items-center gap-2 mt-5 text-sm font-medium text-[var(--color-link)] no-underline hover:underline min-h-[44px]"
            >
              Ver perfil completo
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}
</article>
