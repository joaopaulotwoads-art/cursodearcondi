---
import { getPostUrl, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { resolveBemmaeMediaUrl } from '../../utils/media-url';

interface Props {
  posts: any[];
  blogData: Record<string, any>;
  blogPermalinkStructure: BlogPermalinkStructure;
  blogUrlPrefix: BlogUrlPrefix;
  /** Nome legível da categoria (quando ?categoria= está na URL). */
  categoryName?: string;
  /** True se havia parâmetro categoria na URL (mesmo sem posts). */
  categoryFilterActive?: boolean;
}

const { posts, blogData: b, blogPermalinkStructure, blogUrlPrefix, categoryName, categoryFilterActive } = Astro.props;
const showCategoryHeading = Boolean(categoryName);
const showUnknownCategory = Boolean(categoryFilterActive && !categoryName);
---
<article class="max-w-4xl mx-auto px-4 py-12">
  <header class="mb-10">
    <h1 class="text-2xl font-semibold text-[var(--color-text)]">
      {showCategoryHeading ? categoryName : showUnknownCategory ? 'Categoria' : b.pageTitle || 'Blog'}
    </h1>
    {showCategoryHeading && (
      <p class="mt-2">
        <a href="/blog" class="text-sm text-[var(--color-accent)] hover:underline">Ver todos os artigos</a>
      </p>
    )}
    {!showCategoryHeading && !showUnknownCategory && (b.heroDescription || b.blogIntro) && (
      <p class="mt-1 text-[var(--color-muted)]">{b.heroDescription || b.blogIntro}</p>
    )}
  </header>
  {posts.length === 0 ? (
    <p class="text-[var(--color-muted)]">{b.emptyMessage || 'Nenhum post publicado ainda.'}</p>
  ) : (
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {posts.map((post) => {
        const url = getPostUrl(post, blogPermalinkStructure, blogUrlPrefix);
        const thumb = resolveBemmaeMediaUrl(post.data.thumbnail || post.data.metaImage);
        const date = post.data.publishedDate;
        return (
          <a
            href={url}
            class="group block rounded-lg border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-accent)] transition-colors"
          >
            {thumb ? (
              <div class="aspect-[4/3] overflow-hidden bg-[var(--color-rosa)]">
                <img
                  src={thumb}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ) : (
              <div class="aspect-[4/3] bg-[var(--color-rosa)] flex items-center justify-center text-[var(--color-muted)] text-sm">—</div>
            )}
            <div class="p-4">
              {date && (
                <time class="text-xs text-[var(--color-muted)]" datetime={date}>
                  {new Date(date).toLocaleDateString('pt-BR')}
                </time>
              )}
              <h2 class="mt-1 font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">{post.data.title}</h2>
              {post.data.metaDescription && (
                <p class="text-sm text-[var(--color-muted)] mt-1 line-clamp-2">{post.data.metaDescription}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}
</article>
