---
interface Props {
  data: Record<string, any>;
}

const { data: d } = Astro.props;
const successMessage = d.formSuccessMessage || 'Mensagem enviada com sucesso! Retornaremos em breve.';
---
<article class="max-w-xl mx-auto px-4 py-12">
  <header class="mb-8">
    <h1 class="text-2xl font-semibold text-[var(--color-text)]">{d.heroTitle || 'Contato'}</h1>
    {d.heroSubtitle && <p class="mt-1 text-[var(--color-muted)]">{d.heroSubtitle}</p>}
  </header>

  {Array.isArray(d.socialLinks) && d.socialLinks.length > 0 && (
    <div class="mb-8">
      <p class="text-sm font-medium text-[var(--color-text)] mb-3">Redes sociais</p>
      <ul class="flex flex-wrap gap-3">
        {d.socialLinks.map((s: { platform: string; url: string; icon?: string }) => (
          <li>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-white px-4 py-2 text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors min-h-[44px]"
            >
              {s.icon === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                </svg>
              )}
              {s.icon === 'pinterest' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
                  <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z" />
                </svg>
              )}
              {s.platform}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {(d.email || d.phone || d.address) && (
    <div class="mb-8 space-y-3 text-sm text-[var(--color-muted)]">
      {d.email && (
        <p>
          <span class="font-medium text-[var(--color-text)]">E-mail: </span>
          <a href={`mailto:${d.email}`} class="text-[var(--color-accent)] hover:underline">{d.email}</a>
        </p>
      )}
      {d.phone && (
        <p>
          <span class="font-medium text-[var(--color-text)]">Telefone: </span>
          <a href={`tel:${String(d.phone).replace(/\D/g, '')}`} class="text-[var(--color-accent)] hover:underline">{d.phone}</a>
        </p>
      )}
      {d.address && (
        <p class="whitespace-pre-line">
          <span class="font-medium text-[var(--color-text)]">Endereço: </span>
          {d.address}
        </p>
      )}
    </div>
  )}

  <form class="space-y-4" id="bem-contact-form" onsubmit="return false;" aria-label="Formulário de contato">
    <div>
      <label for="bem-nome" class="block text-sm font-medium text-[var(--color-text)] mb-1">Nome</label>
      <input id="bem-nome" type="text" name="nome" required class="w-full min-h-[44px] px-4 rounded-md border border-[var(--color-border)] bg-white text-[var(--color-text)]" />
    </div>
    <div>
      <label for="bem-email" class="block text-sm font-medium text-[var(--color-text)] mb-1">E-mail</label>
      <input id="bem-email" type="email" name="email" required class="w-full min-h-[44px] px-4 rounded-md border border-[var(--color-border)] bg-white text-[var(--color-text)]" />
    </div>
    <div>
      <label for="bem-mensagem" class="block text-sm font-medium text-[var(--color-text)] mb-1">Mensagem</label>
      <textarea id="bem-mensagem" name="mensagem" rows="4" required class="w-full min-h-[44px] px-4 py-3 rounded-md border border-[var(--color-border)] bg-white text-[var(--color-text)]" />
    </div>
    <button type="submit" class="min-h-[44px] px-5 py-2.5 rounded-md bg-[var(--color-accent)] text-white font-medium hover:opacity-90">
      {d.formSubmitText || 'Enviar'}
    </button>
    <div id="bem-form-message" class="hidden p-3 rounded-md text-sm" />
  </form>
</article>

<script define:vars={{ successMessage }}>
  const form = document.getElementById('bem-contact-form');
  const msg = document.getElementById('bem-form-message');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !msg) return;
    const name = (form.querySelector('[name="nome"]'))?.value?.trim() || '';
    const email = (form.querySelector('[name="email"]'))?.value?.trim() || '';
    const message = (form.querySelector('[name="mensagem"]'))?.value?.trim() || '';
    msg.classList.remove('hidden', 'bg-red-100', 'text-red-800', 'bg-green-100', 'text-green-800');
    msg.textContent = 'Enviando...';
    msg.classList.remove('hidden');
    try {
      const res = await fetch('/api/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message, subject: 'Contato site', source: 'contato' }),
      });
      const data = await res.json();
      if (data.success) {
        msg.textContent = successMessage;
        msg.classList.add('bg-green-100', 'text-green-800');
        form.reset();
      } else {
        msg.textContent = data.error || 'Erro ao enviar.';
        msg.classList.add('bg-red-100', 'text-red-800');
      }
    } catch {
      msg.textContent = 'Erro de conexão.';
      msg.classList.add('bg-red-100', 'text-red-800');
    }
  });
</script>
