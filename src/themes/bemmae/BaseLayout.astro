---
import Header from './Header.astro';
import Footer from './Footer.astro';
import type { NavItem } from './types';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import './global.css';

interface Props {
  title: string;
  description?: string;
  siteName: string;
  /** Caminho público do logo (ex.: /bemmae-logo.png) quando definido no singleton Menu. */
  logoSrc?: string;
  siteUrl: string;
  nav: NavItem[];
  footerNav: NavItem[];
  /** Singletons do rodapé (ex.: bemmae) */
  contentThemeId?: string;
  ogType?: 'website' | 'article';
  ogImageAbs?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  extraJsonLd?: Record<string, unknown> | null;
}

const {
  title,
  description,
  siteName,
  logoSrc,
  siteUrl,
  nav,
  footerNav,
  contentThemeId = 'bemmae',
  ogType = 'website',
  ogImageAbs,
  articlePublishedTime,
  articleModifiedTime,
  extraJsonLd,
} = Astro.props;
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const fullDescription = description || '';
---
<!DOCTYPE html>
<html lang="pt-BR" class="bemmae-root">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/bemmae-favicon.svg" />
  <link rel="apple-touch-icon" href="/bemmae-favicon.svg" />
  <meta name="theme-color" content="#faf8f6" />
  <title>{fullTitle}</title>
  <meta name="description" content={fullDescription} />
  <link rel="canonical" href={`${siteUrl.replace(/\/+$/, '')}${Astro.url.pathname || '/'}`} />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={fullDescription} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:locale" content="pt_BR" />
  {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}
  <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={fullDescription} />
  {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
  <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'WebSite', name: siteName, url: siteUrl, description: fullDescription || undefined })} />
  {extraJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(extraJsonLd)} />
  )}
</head>
<body class="bemmae-scope bg-[var(--color-bg)] text-[var(--color-text)] antialiased">
  <Header siteName={siteName} logoSrc={logoSrc} nav={nav} />
  <main><slot /></main>
  <Footer siteName={siteName} logoSrc={logoSrc} footerNav={footerNav} contentThemeId={contentThemeId} />
</body>
</html>
