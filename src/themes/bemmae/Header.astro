---
import type { NavItem } from './types';

interface Props {
  siteName: string;
  nav: NavItem[];
  logoSrc?: string;
}

const { siteName, nav, logoSrc } = Astro.props;
---
<header class="bg-[var(--color-bg)] border-b border-[var(--color-border)] sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4 py-4 sm:py-5 flex items-center justify-between gap-4 md:gap-6">
    <a href="/" class="flex items-center min-h-[44px] shrink-0" aria-label={siteName}>
      {logoSrc ? (
        <img
          src={logoSrc}
          alt=""
          width="480"
          height="108"
          class="h-14 w-auto sm:h-[4.5rem] md:h-20 lg:h-[5.5rem] max-w-[min(92vw,28rem)] sm:max-w-[min(90vw,32rem)] md:max-w-none object-contain object-left"
          decoding="async"
          fetchpriority="low"
        />
      ) : (
        <span class="text-lg font-semibold text-[var(--color-heading)]">{siteName}</span>
      )}
    </a>
    <nav class="hidden md:flex items-center gap-6" aria-label="Navegação">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-[var(--color-text)] no-underline hover:text-[var(--color-link)] hover:underline min-h-[44px] flex items-center"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button type="button" id="bem-mobile-menu-btn" class="md:hidden p-2 min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Abrir menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </div>
  <div id="bem-mobile-menu" class="md:hidden hidden border-t border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-4">
    <nav class="flex flex-col gap-2">
      {nav.map((item) => (
        <a
          href={item.href}
          class="bem-mobile-nav-link py-3 min-h-[44px] flex items-center text-sm font-medium text-[var(--color-text)] no-underline hover:text-[var(--color-link)] hover:underline"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
<script>
  document.getElementById('bem-mobile-menu-btn')?.addEventListener('click', () => document.getElementById('bem-mobile-menu')?.classList.toggle('hidden'));
  document.querySelectorAll('.bem-mobile-nav-link').forEach((link) => link.addEventListener('click', () => document.getElementById('bem-mobile-menu')?.classList.add('hidden')));
</script>
