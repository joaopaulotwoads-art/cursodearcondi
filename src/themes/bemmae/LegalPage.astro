---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<article class="max-w-2xl mx-auto px-4 py-12">
  <h1 class="text-2xl font-semibold text-[var(--color-text)] mb-8">{title}</h1>
  <div class="prose prose-neutral max-w-none text-[var(--color-text)] prose-headings:text-[var(--color-text)] prose-a:text-[var(--color-accent)]">
    <slot />
  </div>
</article>
