---
import { curriculumModules } from '../../data/curriculum-cursodear';

interface Props {
  /** Qual `<details>` inicia aberto: índice 0-based, ou `-1` para todos fechados. */
  openIndex?: number;
}

const { openIndex = 0 } = Astro.props;
---

<ol class="list-none space-y-3 p-0">
  {
    curriculumModules.map((mod, i) => (
      <li>
        <details
          class="group rounded-xl border border-slate-200 bg-slate-50 p-4 sm:p-5 shadow-sm open:border-blue-200 open:bg-white"
          open={openIndex === -1 ? false : i === openIndex}
        >
          <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-left text-base font-bold text-slate-900 sm:text-lg">
                Módulo {mod.id} — {mod.title}
              </h3>
              <span class="shrink-0 rounded-full bg-slate-200/80 px-2.5 py-0.5 text-xs font-semibold text-slate-600 group-open:bg-blue-100 group-open:text-blue-800">
                {mod.lessons.length} aulas
              </span>
            </div>
          </summary>
          <ul class="mt-4 list-none space-y-1.5 border-t border-slate-200/80 pt-4 text-sm leading-snug text-slate-700">
            {mod.lessons.map((item) => (
              <li class="flex gap-2 pl-0">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-blue-600" aria-hidden="true" />
                <span class="min-w-0 flex-1">{item}</span>
              </li>
            ))}
          </ul>
        </details>
      </li>
    ))
  }
</ol>
