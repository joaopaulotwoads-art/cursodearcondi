---
import { curriculumModules } from '../../data/curriculum-cursodear';
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
  {
    curriculumModules.map((mod) => (
      <article
        class="group flex flex-col rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md"
        aria-labelledby={`mod-${mod.id}-title`}
      >
        <div class="flex items-start justify-between gap-2">
          <span class="inline-flex h-8 min-w-9 items-center justify-center rounded-lg bg-slate-900 text-xs font-black text-white">
            {mod.id}
          </span>
          <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-600">
            {mod.lessons.length} aulas
          </span>
        </div>
        <h3 id={`mod-${mod.id}-title`} class="mt-3 text-base font-bold leading-snug text-slate-900 sm:text-lg">
          {mod.title}
        </h3>
        <ul
          class="mt-3 min-h-0 max-h-56 flex-1 list-none space-y-1.5 overflow-y-auto overscroll-y-contain pr-1 text-sm leading-snug text-slate-600 [scrollbar-gutter:stable] sm:max-h-64"
        >
          {mod.lessons.map((item) => (
            <li class="flex gap-2 border-b border-slate-100/80 py-0.5 last:border-0">
              <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-blue-500/80" aria-hidden="true" />
              <span class="min-w-0 flex-1">{item}</span>
            </li>
          ))}
        </ul>
      </article>
    ))
  }
</div>
