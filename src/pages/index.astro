---
import { getEntry } from 'astro:content';
import BaseLayoutcursodear from '../themes/cursodear/BaseLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const pageTitle = 'Curso de Ar Condicionado online | Formação Profissional 2026';
const pageDescription = 'Curso de Ar Condicionado com acesso imediato, certificado e formação completa para instalação e manutenção.';
const hotmartAffiliateUrl = 'https://go.hotmart.com/R103468777C?dp=1';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);
const canonicalHomeUrl = 'https://cursodearcondicionado.com.br/';

const beMenu = (await readSingleton('menu', 'cursodear')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'cursodear')) as Record<string, unknown> | null;
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);

const aprenderItems = [
  'Instalação completa de ar-split residencial e comercial',
  'Manutenção corretiva e preventiva passo a passo',
  'Limpeza e higienização profissional',
  'Diagnóstico de falhas elétricas e mecânicas',
  'Uso do manifold e manômetro',
  'Recolhimento e recarga de fluído refrigerante R410A',
  'Teste e troca de capacitores',
  'Teste e ligação de compressores',
  'Diagnóstico e reparo de placas eletrônicas',
  'Tecnologia Inverter (LG Dual Inverter e Consul Inverter)',
  'Brasagem (solda) com nitrogênio passante',
  'Dimensionamento de BTUs, cabos e disjuntores',
  'Teste de estanqueidade e vácuo no sistema',
  'Super aquecimento e teste Delta T (rendimento)',
  'Teste de sensores e uso do app Refrigerant Slider',
  'Como emitir certificado e acessar o curso pela Hotmart',
];

const aulas = [
  { number: '01', title: 'Módulo 01 - Aulas Iniciais', count: '19 aulas', text: 'Apresentação, acesso à área do aluno, suporte, ferramentas (2 partes), PDF de ferramentas, tipos de ar, termodinâmica, condensadora (3) e desmontagem da evaporadora (3).' },
  { number: '02', title: 'Módulo 02 - Eletricidade', count: '9 aulas', text: 'Grandezas elétricas, corrente alternada, resistência, potência, efeito nas cargas, problemas de corrente (2) e uso de alicate amperímetro e multímetro (2).' },
  { number: '03', title: 'Módulo 03 - Capacitores', count: '4 aulas', text: 'Capacitor permanente, teste com multímetro e capacímetro e como escolher o capacitor correto para cada aplicação.' },
  { number: '04', title: 'Módulo 04 - Motor Ventilador', count: '4 aulas', text: 'Cargas indutivas e capacitivas, ligação do motor ventilador em 3 partes e prática em bancada.' },
  { number: '05', title: 'Módulo 05 - Manifold', count: '2 aulas', text: 'Apresentação do manifold e uso prático em duas aulas com leitura e interpretação de pressão.' },
  { number: '06', title: 'Módulo 06 - Compressor', count: '15 aulas', text: 'Bobinas (3), testes de compressor e protetor (2), compressão (5), ligação na condensadora (2), motor ventilador, capacitor de 3 polos e troca de óleo.' },
  { number: '07', title: 'Módulo 07 - Placa Evaporadora Convencional', count: '16 aulas', text: 'Teste completo da placa da evaporadora em 16 partes e teste do relé da placa.' },
  { number: '08', title: 'Módulo 08 - Sensores', count: '3 aulas', text: 'Teste de sensor em 2 partes e uso do aplicativo ajuda técnico.' },
  { number: '09', title: 'Módulo 09 - Instalação de Ar Split', count: '47 aulas', text: 'Tubulação, flange (3), alargamento para brasagem, BTUs, cabo/disjuntor, sifão, instalação evaporadora (12), condensadora (7), estanqueidade (4), vácuo (6) e ligação final.' },
  { number: '10', title: 'Módulo 10 - Pós-instalação', count: '7 aulas', text: 'Teste de rendimento Delta T (3), super aquecimento (3), app Refrigerant Slider e aplicação prática do super aquecimento.' },
  { number: '11', title: 'Módulo 11 - Brasagem', count: '3 aulas', text: 'Brasagem (solda) com nitrogênio passante em 3 partes.' },
  { number: '12', title: 'Módulo 12 - Recolhimento do Fluído Refrigerante / R410A', count: '6 aulas', text: 'Recolhimento do R410A em 4 partes e funcionamento após recolhimento em 2 partes.' },
  { number: '13', title: 'Módulo 13 - Tecnologia Inverter', count: '19 aulas', text: 'LG Dual Inverter, condensadora inverter, ligação elétrica (2), comunicação (3), placa LG (6), teste IPM, compressor inverter, diagnósticos, reator e sensor de descarga (2).' },
  { number: '14', title: 'Módulo 14 - Consul Inverter', count: '4 aulas', text: 'Orientações iniciais, teste de tensão e sinal na evaporadora, checkup na condensadora e diagnóstico final.' },
  { number: '15', title: 'Módulo 15 - Manutenção Corretiva e Preventiva', count: '10 aulas', text: 'Manutenção corretiva (5), recolhimento de fluído e diagnóstico, manutenção preventiva (3) e considerações finais.' },
];

const faqItems = [
  { q: 'O curso é totalmente online?', a: 'Sim. O acesso é feito pela plataforma Hotmart, podendo assistir pelo celular ou computador, a qualquer hora.' },
  { q: 'Por quanto tempo tenho acesso?', a: 'O acesso é vitalício. O curso não expira e você pode assistir quantas vezes quiser.' },
  { q: 'Recebo certificado?', a: 'Sim! Ao concluir você recebe certificado de conclusão para baixar direto pela Hotmart.' },
  { q: 'Serve para iniciantes?', a: 'Sim! O curso começa do zero, sem exigir conhecimento prévio. Qualquer pessoa consegue aprender.' },
  { q: 'Qual é a garantia?', a: 'Garantia incondicional de 15 dias. Se não gostar por qualquer motivo, basta solicitar o reembolso.' },
  { q: 'Em quantas vezes posso parcelar?', a: 'Em até 12x de R$ 20,37 no cartão, ou R$ 197,00 à vista.' },
  { q: 'Terei suporte durante o curso?', a: 'Sim! Há suporte disponível para dúvidas técnicas ao longo do curso.' },
];
---

<BaseLayoutcursodear
  title={pageTitle}
  description={pageDescription}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={[]}
  footerNav={beFootNav}
  contentThemeId="cursodear"
  canonicalOverride={canonicalHomeUrl}
>
  <div class="bg-white text-slate-900">
    <!-- 2. HERO -->
    <section
      class="relative min-h-[650px] overflow-hidden"
      style="background-image: url('/images/hero-bg.webp'); background-size: cover; background-position: center top;"
    >
      <!-- TODO: adicionar imagem de fundo real aqui -->
      <div class="absolute inset-0 bg-black/60"></div>
      <div class="mx-auto flex flex-col md:flex-row items-start gap-8 px-4 md:px-6 py-10 md:py-20 max-w-6xl relative">
        <div class="grid w-full gap-8 md:grid-cols-[1.1fr,0.9fr]">
          <div class="text-white">
            <span class="bg-orange-500 text-white text-xs font-bold px-4 py-1.5 rounded uppercase tracking-widest">
              Melhor Curso de Ar Condicionado do Mercado
            </span>
            <h1 class="text-3xl md:text-6xl font-black text-white leading-tight mt-4">Curso de Ar Condicionado</h1>
            <p class="text-gray-200 text-lg mt-4 max-w-lg leading-relaxed">
              Domine instalação, manutenção e limpeza de ar condicionado com método direto ao ponto para gerar resultado rápido.
            </p>
            <div class="flex items-center gap-2 mt-6 text-white text-sm">
              <span class="text-yellow-400">★★★★★</span>
              <span class="font-bold">4.7</span>
              <span class="text-gray-300">(189 avaliações)</span>
              <span class="text-gray-400">·</span>
              <span class="text-gray-300">+11.900 alunos</span>
              <span class="text-gray-400">·</span>
              <span class="text-gray-300">94% positivas</span>
            </div>
            <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-2">
              <p class="flex items-center gap-2 rounded-lg bg-white/10 px-3 py-2 text-white text-sm"><span class="text-orange-500">✓</span><span>160 aulas e 30 horas de conteúdo</span></p>
              <p class="flex items-center gap-2 rounded-lg bg-white/10 px-3 py-2 text-white text-sm"><span class="text-orange-500">✓</span><span>Acesso vitalício ao curso</span></p>
              <p class="flex items-center gap-2 rounded-lg bg-white/10 px-3 py-2 text-white text-sm"><span class="text-orange-500">✓</span><span>Certificado de conclusão</span></p>
              <p class="flex items-center gap-2 rounded-lg bg-white/10 px-3 py-2 text-white text-sm"><span class="text-orange-500">✓</span><span>Garantia de 15 dias</span></p>
            </div>
          </div>
          <aside class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-2xl overflow-hidden">
            <div class="mb-4 rounded-xl bg-slate-800 p-4">
              <p class="text-center text-[11px] font-semibold uppercase tracking-[0.16em] text-orange-300">OFERTA ESPECIAL DE MATRÍCULA</p>
              <div class="mt-3 flex items-center justify-between gap-2">
                <div class="text-center">
                  <div class="min-w-[52px] md:min-w-[60px] rounded border border-slate-600 bg-slate-700 px-2 md:px-3 py-2 text-center">
                    <p id="countdown-days" class="text-xl md:text-3xl font-black text-white">00</p>
                    <p class="text-xs uppercase text-gray-400">DIAS</p>
                  </div>
                </div>
                <span class="text-xl text-white">:</span>
                <div class="text-center">
                  <div class="min-w-[52px] md:min-w-[60px] rounded border border-slate-600 bg-slate-700 px-2 md:px-3 py-2 text-center">
                    <p id="countdown-hours" class="text-xl md:text-3xl font-black text-white">00</p>
                    <p class="text-xs uppercase text-gray-400">HRS</p>
                  </div>
                </div>
                <span class="text-xl text-white">:</span>
                <div class="text-center">
                  <div class="min-w-[52px] md:min-w-[60px] rounded border border-slate-600 bg-slate-700 px-2 md:px-3 py-2 text-center">
                    <p id="countdown-minutes" class="text-xl md:text-3xl font-black text-white">00</p>
                    <p class="text-xs uppercase text-gray-400">MIN</p>
                  </div>
                </div>
                <span class="text-xl text-white">:</span>
                <div class="text-center">
                  <div class="min-w-[52px] md:min-w-[60px] rounded border border-slate-600 bg-slate-700 px-2 md:px-3 py-2 text-center">
                    <p id="countdown-seconds" class="text-xl md:text-3xl font-black text-white">00</p>
                    <p class="text-xs uppercase text-gray-400">SEG</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex justify-center mb-2">
              <span class="bg-red-500 text-white text-xs font-bold px-4 py-1 rounded-full uppercase">MAIS VENDIDO</span>
            </div>
            <p class="text-gray-400 text-sm line-through text-center mt-3">De R$ 297,00</p>
            <p class="text-orange-500 font-black text-4xl md:text-5xl text-center leading-none">R$ 197,00</p>
            <p class="text-gray-500 text-sm text-center mt-1">ou 12x de R$ 20,37 no cartão</p>
            <a
              href={hotmartAffiliateUrl}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="mt-4 w-full block bg-green-500 hover:bg-green-600 text-white font-black py-4 rounded-xl text-center text-lg uppercase tracking-wide transition"
            >
              QUERO ME INSCREVER AGORA
            </a>
            <p class="text-center text-gray-400 text-xs mt-2">🔒 Compra 100% segura pela Hotmart</p>
            <p class="mt-4 border-t pt-4 text-sm leading-relaxed text-gray-700">
              Ao entrar hoje, você recebe acesso imediato a todo o treinamento com mais de 160 aulas, trilha completa de 30 horas, certificado de conclusão e suporte para dúvidas técnicas. O conteúdo foi montado para acelerar sua entrada no mercado de instalação e manutenção, com acesso vitalício para revisão e garantia incondicional de 15 dias.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <!-- 3. APRENDIZADO -->
    <section class="bg-white py-16 md:py-24" id="o-que-aprender">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <h2 class="text-center text-3xl font-bold text-[#1e293b]">O QUE VOCÊ VAI APRENDER NO CURSO DE AR CONDICIONADO</h2>
        <div class="w-16 h-1 bg-orange-500 mx-auto mt-3 mb-6 rounded"></div>
        <p class="mx-auto mt-3 max-w-3xl text-center text-sm text-gray-500">Aprenda do zero ao avançado com aulas práticas, suporte e método validado por milhares de alunos.</p>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-3">
          {aprenderItems.map((item) => (
            <p class="flex items-start gap-2 rounded-lg border border-transparent p-2 text-sm text-[#374151] transition hover:border-orange-200 hover:bg-orange-50">
              <span class="w-5 h-5 rounded-full bg-orange-500 text-white flex items-center justify-center text-xs flex-shrink-0">✓</span>
              <span>{item}</span>
            </p>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. CONTEÚDO DO CURSO -->
    <section class="bg-[#f8fafc] py-16 md:py-24" id="modulos">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <h2 class="text-3xl font-bold text-[#1e293b]">Conteúdo do Curso de Ar Condicionado</h2>
        <div class="mt-6">
          {aulas.map((aula) => (
            <details class="group mb-3 overflow-hidden rounded-xl border border-gray-200 shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between bg-white px-4 md:px-5 py-4 font-semibold text-gray-800 transition-colors hover:bg-orange-50 [&::-webkit-details-marker]:hidden">
                <div class="flex items-center gap-3">
                  <span class="w-8 h-8 rounded-full bg-orange-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">{aula.number}</span>
                  <span class="text-sm md:text-base">{aula.title}</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="bg-gray-100 text-gray-500 text-xs px-2 py-1 rounded-full">{aula.count}</span>
                  <span class="text-gray-400 text-lg after:content-['+'] group-open:after:content-['×']"></span>
                </div>
              </summary>
              <p class="border-t border-orange-100 bg-orange-50 px-4 md:px-5 py-4 text-sm leading-relaxed text-gray-600">{aula.text}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. APRENDIZADO DETALHADO -->
    <section class="py-16 md:py-24" id="instrutor">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <h2 class="text-3xl font-bold text-slate-900">PARA QUEM É ESTE CURSO</h2>
        <div class="mt-6 space-y-4 text-sm leading-relaxed text-slate-700">
          <p>
            Este curso foi estruturado para profissionais em diferentes estágios da carreira: quem está começando do zero, quem já atende clientes no residencial, eletricistas que desejam expandir escopo de serviço e técnicos de manutenção predial que precisam elevar padrão técnico com mais segurança e produtividade.
          </p>
          <p>
            Também é indicado para quem já atua como autônomo e quer organizar melhor o processo de orçamento, instalação, manutenção corretiva e preventiva, aumentando taxa de fechamento e margem por atendimento. A trilha contempla desde fundamentos até tecnologia Inverter para quem deseja se posicionar em nichos de maior valor.
          </p>
          <p>
            Para profissionais que buscam transição de carreira, o treinamento entrega uma base prática e comercial para construir autoridade local, gerar indicações e transformar conhecimento técnico em renda recorrente com contratos de manutenção e atendimento de emergência.
          </p>
        </div>
      </div>
    </section>

    <!-- 6. DESCRIÇÃO DO CURSO -->
    <section class="py-16 md:py-24" id="descricao-curso">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <h2 class="text-3xl font-bold text-slate-900">Descrição do Curso de Ar Condicionado</h2>
        <div class="mt-6 space-y-4 text-sm leading-relaxed text-slate-700">
          <p>O Curso de Ar Condicionado é uma formação completa para quem quer entrar no mercado de climatização com autoridade, executar serviços com qualidade e criar faturamento recorrente com instalações e manutenções. Com 160 aulas e 30 horas de conteúdo, você aprende do zero até a tecnologia Inverter.</p>
          <p>O curso cobre desde o funcionamento básico de um ar-condicionado split, eletricidade aplicada, capacitores, compressores e placas eletrônicas, até a instalação completa com tubulação, vácuo, teste de estanqueidade e recarga de gás R410A. Você aprende fazendo, com aulas gravadas na prática.</p>
          <p>Além disso, você vai dominar a tecnologia Inverter com os modelos LG Dual Inverter e Consul Inverter, aprender brasagem com nitrogênio passante, manutenção corretiva e preventiva — tudo o que o mercado exige de um técnico qualificado.</p>
          <p>+11.900 alunos já transformaram suas carreiras com esse método. Com certificado reconhecido, acesso vitalício e garantia de 15 dias, você não tem nada a perder. Comece hoje e saia cobrando pelo seu serviço.</p>
        </div>
        <div class="mt-8 grid grid-cols-2 md:grid-cols-4 overflow-hidden rounded-2xl bg-gradient-to-r from-slate-800 to-slate-900">
          <article class="border-b border-slate-700 px-4 py-6 text-center md:border-b-0 md:border-r">
            <p class="text-2xl">👥</p>
            <p class="mt-1 text-3xl md:text-4xl font-black text-orange-500">+11.900</p>
            <p class="mt-1 text-sm uppercase tracking-wider text-gray-400">Alunos formados</p>
          </article>
          <article class="border-b border-slate-700 px-4 py-6 text-center md:border-b-0 md:border-r">
            <p class="text-2xl">🎬</p>
            <p class="mt-1 text-3xl md:text-4xl font-black text-orange-500">160</p>
            <p class="mt-1 text-sm uppercase tracking-wider text-gray-400">Aulas gravadas</p>
          </article>
          <article class="border-b border-slate-700 px-4 py-6 text-center md:border-b-0 md:border-r">
            <p class="text-2xl">⏱️</p>
            <p class="mt-1 text-3xl md:text-4xl font-black text-orange-500">30h</p>
            <p class="mt-1 text-sm uppercase tracking-wider text-gray-400">De conteúdo</p>
          </article>
          <article class="px-4 py-6 text-center">
            <p class="text-2xl">⭐</p>
            <p class="mt-1 text-3xl md:text-4xl font-black text-orange-500">4.7⭐</p>
            <p class="mt-1 text-sm uppercase tracking-wider text-gray-400">Avaliação média</p>
          </article>
        </div>
      </div>
    </section>

    <!-- 7. INSTRUTOR -->
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <p class="mb-2 text-sm font-bold uppercase tracking-[0.18em] text-orange-500">INSTRUTOR</p>
        <article class="rounded-2xl border border-gray-200 bg-white p-8 shadow-md">
          <div class="flex flex-col md:flex-row items-start gap-8">
            <img
              src="/images/leandro.webp"
              alt="Instrutor Leandro Moraes"
              class="w-40 h-40 rounded-full object-cover object-top border-4 border-orange-500 shadow-lg flex-shrink-0 mx-auto md:mx-0"
              loading="lazy"
              decoding="async"
            />
            <div class="flex-1 text-center md:text-left">
              <h3 class="text-2xl font-black uppercase text-slate-800">INSTRUTOR LEANDRO MORAES</h3>
              <p class="mb-4 text-sm font-semibold text-orange-500">Especialista em Refrigeração e Climatização</p>
              <p class="mt-4 text-sm leading-relaxed text-slate-700">
                Com mais de 20 anos de experiência em refrigeração e climatização, Leandro reúne vivência de campo, rotina de atendimento real e prática de ensino voltada para resultado financeiro do aluno. Seu método combina explicação técnica clara, passo a passo de execução e foco em erros que mais geram retrabalho.
              </p>
              <p class="mt-3 text-sm leading-relaxed text-slate-700">
                Ao longo da carreira, já treinou milhares de profissionais em todo o Brasil, com ênfase em instalação, manutenção e diagnóstico de equipamentos convencionais e Inverter. A proposta é transformar conhecimento em serviço com padrão profissional, reforçando autoridade, confiança do cliente e evolução de faturamento.
              </p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- 8. CERTIFICAÇÃO -->
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-6xl px-4 md:px-0">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <div class="grid items-start gap-6 md:grid-cols-2">
            <div class="flex items-start gap-4">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[#F97316] text-2xl font-bold text-white">✓</span>
              <div>
                <h2 class="text-2xl font-bold text-slate-900">NOSSA CERTIFICAÇÃO É RECONHECIDA EM TODO O BRASIL</h2>
                <p class="mt-3 text-sm leading-relaxed text-slate-700">
                  Ao concluir o curso, você recebe certificado de conclusão pela plataforma Hotmart. O documento comprova sua participação e reforça sua credibilidade profissional para atuar no mercado de climatização.
                </p>
              </div>
            </div>
            <img
              src="/images/certificado_curso.webp"
              alt="Certificado do Curso de Ar Condicionado"
              class="rounded-xl shadow-lg w-full max-w-sm mx-auto border border-gray-200"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 9. BÔNUS -->
    <section class="bg-white">
      <div class="mx-auto flex max-w-5xl flex-col md:flex-row items-center gap-12 px-6 py-16">
        <div class="flex-1">
          <span class="text-sm font-black uppercase tracking-widest text-orange-500">BÔNUS 01</span>
          <h3 class="mt-2 mb-4 text-2xl font-black text-slate-800">Bônus de Ar Condicionado Inverter</h3>
          <p class="text-gray-600 leading-relaxed">Módulo completo e exclusivo sobre tecnologia Inverter: LG Dual Inverter, Consul Inverter, diagnósticos avançados, teste de IPM, compressor inverter e muito mais. Conteúdo que a maioria dos cursos cobra separado.</p>
