  <script>
    (() => {
      const hourEl = document.getElementById('countdown-hours');
      const minEl = document.getElementById('countdown-minutes');
      const secEl = document.getElementById('countdown-seconds');
      if (!hourEl || !minEl || !secEl) return;

      const KEY = 'cursodear_offer_timer_ends_at';
      const DURATION_MS = 45 * 60 * 1000;

      function getOrCreateEndAt() {
        try {
          const raw = localStorage.getItem(KEY) || '';
          const n = Number(raw);
          if (Number.isFinite(n) && n > Date.now()) return n;
        } catch {
          // ignore
        }
        const endAt = Date.now() + DURATION_MS;
        try {
          localStorage.setItem(KEY, String(endAt));
        } catch {
          // ignore
        }
        return endAt;
      }

      let endAt = getOrCreateEndAt();

      function updateCountdown() {
        const diff = endAt - Date.now();
        if (diff <= 0) {
          // Reinicia o ciclo para manter urgência por sessão/visita
          endAt = Date.now() + DURATION_MS;
          try {
            localStorage.setItem(KEY, String(endAt));
          } catch {
            // ignore
          }
        }

        const t = Math.max(0, endAt - Date.now());
        const hours = Math.floor(t / (1000 * 60 * 60));
        const minutes = Math.floor((t % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((t % (1000 * 60)) / 1000);

        hourEl.textContent = String(hours).padStart(2, '0');
        minEl.textContent = String(minutes).padStart(2, '0');
        secEl.textContent = String(seconds).padStart(2, '0');
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    })();
  </script>

