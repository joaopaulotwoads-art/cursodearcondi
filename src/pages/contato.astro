---
import { getEntry } from 'astro:content';
import BaseLayoutcursodear from '../themes/cursodear/BaseLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const pageTitle = 'Fale Conosco | Suporte ao Aluno';
const pageDescription = 'Entre em contato com nossa equipe de suporte. WhatsApp (14) 98803-4123 ou e-mail. Respondemos em até 24 horas úteis.';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const beMenu = (await readSingleton('menu', 'cursodear')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'cursodear')) as Record<string, unknown> | null;
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);

const contactSchemaJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contato | Curso de Ar Condicionado',
  url: 'https://cursodearcondicionado.com.br/contato',
  publisher: {
    '@type': 'Organization',
    name: 'Curso de Ar Condicionado',
    telephone: '+55-14-98803-4123',
    email: 'contato@cursodearcondicionado.com.br',
  },
};
---

<BaseLayoutcursodear
  title={pageTitle}
  description={pageDescription}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={beNav}
  footerNav={beFootNav}
  contentThemeId="cursodear"
  extraJsonLd={contactSchemaJsonLd}
  canonicalOverride="https://cursodearcondicionado.com.br/contato"
>
  <div class="bg-white text-slate-900">
    <section class="bg-slate-800 py-16 text-center">
      <div class="mx-auto max-w-4xl px-6">
        <span class="text-orange-500 font-bold text-xs uppercase tracking-widest">
          FALE CONOSCO
        </span>
        <h1 class="text-4xl font-black text-white mt-2 mb-4">
          Entre em Contato
        </h1>
        <p class="text-gray-300 max-w-xl mx-auto text-base leading-relaxed">
          Tire suas dúvidas sobre o curso, suporte técnico
          ou qualquer outra informação. Respondemos em até
          24 horas úteis.
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a
          href="https://wa.me/5514988034123"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-green-500 hover:bg-green-600 text-white rounded-2xl p-8 text-center flex flex-col items-center gap-3 transition shadow-lg"
        >
          <span class="text-4xl">💬</span>
          <h3 class="font-black text-lg">WhatsApp</h3>
          <p class="text-green-100 text-sm">(14) 98803-4123</p>
          <span class="bg-white text-green-600 font-bold text-xs px-4 py-2 rounded-full uppercase">
            Chamar agora →
          </span>
        </a>

        <a
          href="mailto:contato@cursodearcondicionado.com.br"
          class="bg-white border-2 border-orange-500 rounded-2xl p-8 text-center flex flex-col items-center gap-3 shadow-lg hover:bg-orange-50 transition"
        >
          <span class="text-4xl">✉️</span>
          <h3 class="font-black text-slate-800 text-lg">E-mail</h3>
          <p class="text-gray-500 text-sm">
            contato@cursodearcondicionado.com.br
          </p>
          <span class="bg-orange-500 text-white font-bold text-xs px-4 py-2 rounded-full uppercase">
            Enviar e-mail →
          </span>
        </a>

        <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center flex flex-col items-center gap-3 shadow-sm">
          <span class="text-4xl">📍</span>
          <h3 class="font-black text-slate-800 text-lg">
            Localização
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Av. Rodrigues Alves, 96<br />
            Jardim Redentor — Bauru/SP
          </p>
          <a
            href="https://maps.app.goo.gl/bAPz55ZAM24twfTo9"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-slate-800 text-white font-bold text-xs px-4 py-2 rounded-full uppercase hover:bg-slate-700 transition"
          >
            Ver no mapa →
          </a>
        </div>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 pb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-black text-slate-800 mb-2">
            Envie sua mensagem
          </h2>
          <p class="text-gray-500 text-sm mb-8">
            Preencha o formulário e responderemos
            em até 24 horas úteis.
          </p>

          <form
            action="https://formsubmit.co/contato@cursodearcondicionado.com.br"
            method="POST"
            class="space-y-4"
          >
            <input type="hidden" name="_subject" value="Nova mensagem - Curso de Ar Condicionado" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://cursodearcondicionado.com.br/contato?enviado=true" />
            <input type="text" name="_honey" style="display:none" />

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Nome completo *</label>
              <input
                type="text"
                name="nome"
                required
                placeholder="Seu nome"
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">E-mail *</label>
              <input
                type="email"
                name="email"
                required
                placeholder="seu@email.com"
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp</label>
              <input
                type="tel"
                name="whatsapp"
                placeholder="(00) 00000-0000"
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition"
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Assunto *</label>
              <select
                name="assunto"
                required
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition bg-white"
              >
                <option value="">Selecione...</option>
                <option value="Dúvida sobre o curso">Dúvida sobre o curso</option>
                <option value="Suporte técnico">Suporte técnico</option>
                <option value="Problemas com acesso">Problemas com acesso</option>
                <option value="Certificado">Certificado</option>
                <option value="Reembolso">Reembolso / Garantia</option>
                <option value="Outros">Outros</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Mensagem *</label>
              <textarea
                name="mensagem"
                required
                rows="5"
                placeholder="Escreva sua mensagem aqui..."
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-orange-500 hover:bg-orange-600 text-white font-black py-4 rounded-xl uppercase tracking-wide transition text-base"
            >
              ENVIAR MENSAGEM →
            </button>

            <p class="text-xs text-gray-400 text-center">
              🔒 Seus dados estão seguros. Não fazemos spam.
            </p>
          </form>
        </div>

        <div class="space-y-8">
          <div class="rounded-2xl overflow-hidden shadow-md border border-gray-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.0615387622606!2d-49.03531582470722!3d-22.313512279677077!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94bf5d70916f0c85%3A0xf9fafa89cf77ec46!2sAv.%20Rodrigues%20Alves%2C%2096%20-%20Jardim%20Redentor%2C%20Bauru%20-%20SP!5e0!3m2!1spt-PT!2sbr!4v1777417609252!5m2!1spt-PT!2sbr"
              width="100%"
              height="280"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-black text-slate-800 text-base mb-4">
              Siga nas redes sociais
            </h3>
            <div class="space-y-3">
              <a
                href="https://instagram.com/cursodearcondicionado"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-orange-500 hover:bg-orange-50 transition group"
              >
                <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center text-white text-lg flex-shrink-0">📸</div>
                <div>
                  <p class="font-semibold text-slate-800 text-sm group-hover:text-orange-500 transition">
                    Instagram
                  </p>
                  <p class="text-gray-400 text-xs">
                    @cursodearcondicionado
                  </p>
                </div>
              </a>

              <a
                href="https://youtube.com/@cursodearcondicionado"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-orange-500 hover:bg-orange-50 transition group"
              >
                <div class="w-10 h-10 bg-red-500 rounded-xl flex items-center justify-center text-white text-lg flex-shrink-0">▶️</div>
                <div>
                  <p class="font-semibold text-slate-800 text-sm group-hover:text-orange-500 transition">
                    YouTube
                  </p>
                  <p class="text-gray-400 text-xs">
                    Curso de Ar Condicionado
                  </p>
                </div>
              </a>

              <a
                href="https://facebook.com/cursodearcondicionado"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-200 hover:border-orange-500 hover:bg-orange-50 transition group"
              >
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white text-lg flex-shrink-0">👍</div>
                <div>
                  <p class="font-semibold text-slate-800 text-sm group-hover:text-orange-500 transition">
                    Facebook
                  </p>
                  <p class="text-gray-400 text-xs">
                    Curso de Ar Condicionado
                  </p>
                </div>
              </a>
            </div>
          </div>

          <div class="bg-orange-50 border border-orange-200 rounded-2xl p-6">
            <h3 class="font-black text-slate-800 text-base mb-3">
              ⏰ Horário de atendimento
            </h3>
            <div class="space-y-1 text-sm text-gray-600">
              <p>Segunda a Sexta: <strong>9h às 18h</strong></p>
              <p>Sábado: <strong>9h às 12h</strong></p>
              <p>Domingo: <strong>Fechado</strong></p>
            </div>
            <p class="text-xs text-gray-400 mt-3">
              Para suporte urgente use o WhatsApp
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    if (params.get('enviado') === 'true') {
      const banner = document.createElement('div');
      banner.className = 'fixed top-20 left-1/2 -translate-x-1/2 z-50 bg-green-500 text-white font-bold px-8 py-4 rounded-2xl shadow-xl text-sm';
      banner.textContent = '✅ Mensagem enviada! Responderemos em breve.';
      document.body.appendChild(banner);
      setTimeout(() => banner.remove(), 5000);
    }
  </script>
</BaseLayoutcursodear>
