---
import { getEntry } from 'astro:content';
import BaseLayoutBemmae from '../themes/bemmae/BaseLayout.astro';
import CurriculumModuleGrid from '../components/cursodear/CurriculumModuleGrid.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';
import { totalLessonCount } from '../data/curriculum-cursodear';

const pageTitle = 'Nossos cursos | Formação em ar condicionado (EAD)';
const pageDescription =
  'Confira módulos e títulos das aulas: do básico à instalação de split, tecnologia Inverter (LG e Consul) e manutenção — grade completa com centenas de vídeos.';

const hotmartAffiliateUrl = 'https://go.hotmart.com/R103468777C?dp=1';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const beMenu = (await readSingleton('menu', 'bemmae')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'bemmae')) as Record<string, unknown> | null;
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);
---

<BaseLayoutBemmae
  title={pageTitle}
  description={pageDescription}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={beNav}
  footerNav={beFootNav}
  contentThemeId="bemmae"
>
  <div class="bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white px-4 py-12 sm:px-6 lg:py-16">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-xs font-bold uppercase tracking-wide text-blue-800">Cursos · Climatização &amp; Refrigeração</p>
        <h1 class="mt-3 text-balance text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">Nossos cursos</h1>
        <p class="mx-auto mt-4 max-w-2xl text-pretty text-slate-700 sm:text-lg">
          Formação 100% online, com aulas objetivas, certificado e conteúdo alinhado ao que você assiste na área do aluno.
        </p>
        <a
          href={hotmartAffiliateUrl}
          target="_blank"
          rel="nofollow noopener noreferrer"
          aria-label="Fazer matrícula no curso (abre a Hotmart em nova aba)"
          class="mt-8 inline-flex min-h-[48px] items-center justify-center rounded-lg bg-blue-900 px-6 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-blue-800"
        >
          Quero me matricular
        </a>
      </div>
    </header>

    <section class="px-4 py-14 sm:px-6 lg:py-16" aria-labelledby="curriculum-heading">
      <div class="mx-auto max-w-7xl">
        <h2 id="curriculum-heading" class="text-center text-2xl font-black text-slate-900 sm:text-3xl">Grade curricular</h2>
        <p class="mx-auto mt-4 max-w-3xl text-center text-slate-700">
          15 módulos com aulas em vídeo — do básico à tecnologia Inverter, instalação de split e manutenção.{' '}
          <span class="mt-2 block text-sm text-slate-600">
            {totalLessonCount} títulos de aula na grade abaixo (navegue em cada bloco; listas longas têm rolagem).
          </span>
        </p>

        <div class="mt-10">
          <CurriculumModuleGrid />
        </div>

        <p class="mt-10 text-center text-sm text-slate-600">
          Voltar para a{' '}
          <a class="font-semibold text-blue-800 underline decoration-blue-200 underline-offset-2 hover:text-blue-700" href="/#matricula">
            oferta e valores na página inicial
          </a>
          .
        </p>
      </div>
    </section>
  </div>
</BaseLayoutBemmae>
