---
/**
 * Rota interna: renderiza post/categoria na raiz quando o pedido foi reescrito
 * desde src/pages/[location]/index.astro (modo blog — evita colisão com páginas de bairro).
 * Não linkar esta URL; o utilizador vê sempre /slug-do-post/ na barra de endereço.
 */
import type { CollectionEntry } from 'astro:content';
import BlogPost from '../../themes/classic/BlogPost.astro';
import BlogList from '../../themes/classic/BlogList.astro';
import BaseLayoutcursodear from '../../themes/cursodear/BaseLayout.astro';
import cursodearBlogPost from '../../themes/cursodear/BlogPost.astro';
import cursodearBlogList from '../../themes/cursodear/BlogList.astro';
import { logoSrcFromMenu } from '../../utils/theme-nav';
import { resolveBlogRootSegment } from '../../utils/blog-root-segment';
import { loadBlogPageData } from '../../utils/load-blog-page-data';

export const prerender = false;

type Props =
  | { kind: 'post'; post: CollectionEntry<'posts'> }
  | { kind: 'category'; category: CollectionEntry<'categories'> };

const { slug } = Astro.params;
const resolved = await resolveBlogRootSegment(slug);
if (resolved.kind === 'notfound') {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const props = resolved as Props;
const publicPath = `/${slug}/`;
const d = await loadBlogPageData(props, publicPath, Astro.url.origin);

const {
  usecursodear,
  layoutType,
  siteName,
  beMenu,
  beFootNav,
  beNav,
  publicSiteUrl,
  post,
  Content,
  htmlContent,
  author,
  documentTitle,
  ogImageAbs,
  articleIso,
  postJsonLd,
  category,
  publishedPosts,
  beBlog,
  pageDesc,
  blogPermalinkStructure,
  blogUrlPrefix,
  relatedPosts,
  blogPermalinkStructureResolved,
  blogUrlPrefixResolved,
} = d;
---

{
  props.kind === 'post' && post ? (
    usecursodear ? (
      <BaseLayoutcursodear
        title={documentTitle}
        description={post.data.metaDescription || ''}
        siteName={(beMenu as { logoText?: string } | null)?.logoText || siteName}
        logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
        siteUrl={publicSiteUrl}
        nav={beNav}
        footerNav={beFootNav}
        contentThemeId="cursodear"
        ogType="article"
        ogImageAbs={ogImageAbs}
        articlePublishedTime={articleIso}
        articleModifiedTime={articleIso}
        extraJsonLd={postJsonLd}
      >
        <cursodearBlogPost
          post={post}
          author={author}
          Content={Content}
          htmlContent={htmlContent}
          relatedPosts={relatedPosts}
          blogPermalinkStructure={blogPermalinkStructureResolved}
          blogUrlPrefix={blogUrlPrefixResolved}
        />
      </BaseLayoutcursodear>
    ) : (
      <BlogPost
        post={post}
        author={author}
        Content={Content}
        htmlContent={htmlContent}
        themeId="classic"
        layoutType={layoutType}
      />
    )
  ) : null
}

{
  props.kind === 'category' && category ? (
    usecursodear ? (
      <BaseLayoutcursodear
        title={`${category.data.name} - ${siteName}`}
        description={pageDesc}
        siteName={(beMenu as { logoText?: string } | null)?.logoText || siteName}
        logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
        siteUrl={publicSiteUrl}
        nav={beNav}
        footerNav={beFootNav}
        contentThemeId="cursodear"
      >
        <cursodearBlogList
          posts={publishedPosts}
          blogData={beBlog}
          blogPermalinkStructure={blogPermalinkStructure}
          blogUrlPrefix={blogUrlPrefix}
          categoryName={category.data.name}
          categoryFilterActive={true}
        />
      </BaseLayoutcursodear>
    ) : (
      <BlogList
        posts={publishedPosts}
        themeId="classic"
        layoutType={layoutType}
        blogPermalinkStructure={blogPermalinkStructure}
        blogUrlPrefix={blogUrlPrefix}
        listTitle={`${category.data.name} — ${siteName}`}
      />
    )
  ) : null
}
