---
/**
 * blog/[...slug].astro
 *
 * Página individual de post com suporte a estrutura de permalink configurável.
 * Aceita: /blog/nome-post | /blog/2025/03/nome-post | /blog/2025/03/04/nome-post
 * Usa layout conforme siteMode: local → LocalLayout, blog → MainLayout.
 */

import { getCollection, getEntry, render } from 'astro:content';
import BlogPost from '../../themes/classic/BlogPost.astro';
import BaseLayoutcursodear from '../../themes/cursodear/BaseLayout.astro';
import cursodearBlogPost from '../../themes/cursodear/BlogPost.astro';
import { readSingleton } from '../../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../../utils/theme-nav';
import { readPost } from '../../utils/post-utils';
import { buildPostPath, type BlogPermalinkStructure, type BlogUrlPrefix } from '../../utils/blog-permalink';
import { pickRelatedPosts } from '../../utils/related-posts';
import { readSiteSettings, resolvePublicSiteUrl, buildCanonicalPageUrl } from '../../utils/read-site-settings';
import {
  buildAuthorAbsoluteUrl,
  buildPostJsonLd,
  toAbsoluteUrl,
  toIsoDateTime,
} from '../../utils/post-json-ld';
import { resolvecursodearMediaUrl } from '../../utils/media-url';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const settings = await getEntry('siteSettings', 'settings').catch(() => null);
  const structure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
  const prefix = (settings?.data?.blogUrlPrefix as string) || 'blog';

  // Só gera paths com /blog quando o prefixo for 'blog'
  if (prefix !== 'blog') return [];

  return posts.map(post => ({
    params: { slug: buildPostPath({ ...post, data: { ...post.data, slug: post.data.slug || post.id } }, structure) },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;

if (!post) return Astro.redirect('/404');

const slugKey = post.data.slug || post.id;
const postFile = await readPost(slugKey);
const htmlContent =
  post.data.contentFormat === 'html' && postFile?.content?.trim()
    ? postFile.content.trim()
    : null;

let Content: (() => unknown) | undefined;
if (!htmlContent) {
  const r = await render(post);
  Content = r.Content;
}

const author = post.data.author ? await getEntry('authors', post.data.author) : null;

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode = (settings?.data?.siteMode || 'blog') as 'blog' | 'local';
const layoutType = siteMode === 'local' ? 'local' : 'main';
const activeTheme = (settings?.data?.activeTheme || 'classic') as string;
const usecursodear = siteMode !== 'local' && activeTheme === 'cursodear';

const siteName = settings?.data?.siteName || 'Site';
const beMenu = usecursodear ? await readSingleton('menu', 'cursodear') : null;
const beFoot = usecursodear ? await readSingleton('footer', 'cursodear') : null;
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const metaTitleTrim = post.data.metaTitle?.trim();
const documentTitle = metaTitleTrim ? metaTitleTrim : `${post.data.title} - ${siteName}`;

const siteCfg = await readSiteSettings();
const publicSiteUrl = resolvePublicSiteUrl(siteCfg.canonicalUrl as string | undefined, Astro.url.origin);
const pageUrl = buildCanonicalPageUrl(publicSiteUrl, Astro.url.pathname);
const rawPostImg = post.data.metaImage || post.data.thumbnail;
const ogImageAbs = toAbsoluteUrl(publicSiteUrl, resolvecursodearMediaUrl(rawPostImg) || rawPostImg);
const articleIso = toIsoDateTime(post.data.publishedDate);
let categoryName: string | undefined;
let categoryPath: string | undefined;
if (post.data.category) {
  const cat = await getEntry('categories', post.data.category).catch(() => null);
  if (cat) {
    categoryName = cat.data.name;
    categoryPath = `/${cat.id}`;
  }
}
const postJsonLd = usecursodear
  ? buildPostJsonLd({
      seoSchema: post.data.seoSchema,
      headline: post.data.title,
      description: post.data.metaDescription || '',
      pageUrl,
      siteUrl: publicSiteUrl,
      siteName: (beMenu as { logoText?: string } | null)?.logoText || siteName,
      publishedDate: post.data.publishedDate,
      imageUrl: ogImageAbs,
      authorName: author?.data?.name,
      authorUrl: author ? buildAuthorAbsoluteUrl(publicSiteUrl, author.id) : undefined,
      htmlContent,
      categoryName,
      categoryPath,
    })
  : null;

const blogPermalinkStructure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';
const blogUrlPrefix = (settings?.data?.blogUrlPrefix as BlogUrlPrefix) || 'blog';
const allPosts = await getCollection('posts');
const relatedPosts = usecursodear ? pickRelatedPosts(post, allPosts, 3) : [];
---

{usecursodear ? (
<BaseLayoutcursodear
    title={documentTitle}
    description={post.data.metaDescription || ''}
    siteName={(beMenu as any)?.logoText || siteName}
    logoSrc={logoSrcFromMenu(beMenu as Record<string, unknown>)}
    siteUrl={publicSiteUrl}
    nav={beNav}
    footerNav={beFootNav}
    contentThemeId="cursodear"
    ogType="article"
    ogImageAbs={ogImageAbs}
    articlePublishedTime={articleIso}
    articleModifiedTime={articleIso}
    extraJsonLd={postJsonLd}
>
    <cursodearBlogPost
      post={post}
      author={author}
      Content={Content}
      htmlContent={htmlContent}
      relatedPosts={relatedPosts}
      blogPermalinkStructure={blogPermalinkStructure}
      blogUrlPrefix={blogUrlPrefix}
    />
</BaseLayoutcursodear>
) : (
<BlogPost
    post={post}
    author={author}
    Content={Content}
    htmlContent={htmlContent}
    themeId="classic"
    layoutType={layoutType}
/>
)}
