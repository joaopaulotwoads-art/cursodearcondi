---
import { getEntry } from 'astro:content';
import BaseLayoutcursodear from '../themes/cursodear/BaseLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';
import { SEO_ORGANIZATION_NAME, ORG_SAME_AS, absoluteUrl, DEFAULT_ORG_LOGO_PATH } from '../utils/seo-meta';

const pageTitle = 'Curso de Ar Condicionado Automotivo Online | Do Zero ao Avançado 2026';
const pageDescription = 'Aprenda ar condicionado automotivo do zero: diagnóstico, recarga de gás, compressor e mais. +6.000 alunos formados. Certificado incluso.';
const pageKeywords = 'curso de ar condicionado automotivo online, curso ar condicionado automotivo, curso de refrigeração automotiva, curso diagnostico ar condicionado carro, curso tecnico ar condicionado automotivo, GL Treinamentos';
const kiwifyUrl = 'https://pay.kiwify.com.br/4KQCJIS?afid=RCDE0GvN';
const canonicalPageUrl = 'https://cursodearcondicionado.com.br/automotivo/';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const beMenu = (await readSingleton('menu', 'cursodear')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'cursodear')) as Record<string, unknown> | null;
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);

const aprenderItems = [
  'Funcionamento completo do sistema de A/C automotivo',
  'Diagnóstico profissional com manifold e detector de vazamento',
  'Recarga de gás R134a e R1234yf',
  'Compressor: tipos, teste e substituição',
  'Condensador e evaporador: limpeza e troca',
  'Válvula de expansão e tubos de orifício',
  'Secador e filtro desidrante',
  'Eletricidade do sistema: relés, fusíveis e pressostatos',
  'Diagnóstico com scanner automotivo',
  'Vedação de vazamentos e recuperação de gás',
  'Manutenção preventiva do sistema de climatização',
  'Gestão e precificação de serviços automotivos',
];

const modulos = [
  { number: '01', title: 'Fundamentos do Ar Condicionado Automotivo', count: '12 aulas', text: 'Ciclo de refrigeração, componentes do sistema, tipos de fluidos refrigerantes, ferramentas obrigatórias e segurança no diagnóstico.' },
  { number: '02', title: 'Fluidos Refrigerantes: R134a e R1234yf', count: '8 aulas', text: 'Diferenças entre R134a e R1234yf, pressões de trabalho, legislação ambiental, recuperação e recarga correta por massa.' },
  { number: '03', title: 'Compressor Automotivo', count: '14 aulas', text: 'Tipos de compressor (pistão, scroll, rotativo), teste de compressão, embreagem magnética, diagnóstico de travamento e troca.' },
  { number: '04', title: 'Condensador e Evaporador', count: '10 aulas', text: 'Função de cada componente, inspeção de obstruções, limpeza química, identificação de vazamento e substituição.' },
  { number: '05', title: 'Válvula de Expansão e Tubo de Orifício', count: '8 aulas', text: 'Diferença entre TXV e tubo de orifício, sintomas de falha, teste com manifold e procedimento de troca.' },
  { number: '06', title: 'Secador / Filtro Desidrante', count: '5 aulas', text: 'Função do secador, quando substituir, posição correta e procedimento de instalação com vácuo.' },
  { number: '07', title: 'Eletricidade do Sistema A/C', count: '12 aulas', text: 'Relés, fusíveis, pressostato de alta e baixa, sensor de temperatura, fan motor e diagnóstico com multímetro.' },
  { number: '08', title: 'Diagnóstico com Scanner', count: '8 aulas', text: 'Leitura de dados do módulo de A/C, PIDs de temperatura e pressão, códigos de falha e interpretação de sensores.' },
  { number: '09', title: 'Detecção e Vedação de Vazamentos', count: '6 aulas', text: 'Detector eletrônico de gás, UV com corante, localização de microvazamentos em mangueiras, conexões e evaporador.' },
  { number: '10', title: 'Manutenção Preventiva', count: '7 aulas', text: 'Higienização do evaporador, troca de filtro de cabine, limpeza do condensador e checklist completo de revisão.' },
  { number: '11', title: 'Gestão e Precificação', count: '5 aulas', text: 'Como precificar serviços de A/C, montagem de orçamento, gestão de estoque de peças e fidelização de clientes.' },
  { number: '12', title: 'Módulo Ganhe Rápido', count: '5 aulas', text: 'Os serviços de maior ticket e maior demanda para começar a faturar nos primeiros dias com o conhecimento do curso.' },
];

const faqItems = [
  { q: 'Qual a diferença para os cursos gratuitos?', a: 'Os cursos gratuitos disponíveis online são apostilas em PDF com teoria introdutória. Servem para ter uma noção do sistema, mas não ensinam diagnóstico real. Este curso tem 100 horas de vídeo aula gravadas em oficina, com demonstração prática de cada procedimento.' },
  { q: 'O curso tem aulas em vídeo ou só material em PDF?', a: '100% em vídeo aula. Cada módulo é demonstrado na prática, com câmera no equipamento, leitura de manifold, diagnóstico elétrico e procedimentos reais de oficina. As apostilas em PDF são complementos, não o conteúdo principal.' },
  { q: 'O curso de ar condicionado automotivo é para iniciantes?', a: 'Sim. O curso começa do zero, explicando o funcionamento do sistema antes de entrar em diagnóstico e manutenção. Não é necessário experiência prévia em mecânica ou refrigeração.' },
  { q: 'Quanto tempo tenho acesso ao curso?', a: 'O acesso é vitalício. Você assiste quantas vezes quiser, pelo celular ou computador, sem prazo de expiração.' },
  { q: 'Recebo certificado ao concluir?', a: 'Sim. Ao finalizar o curso você recebe o certificado de conclusão que pode ser baixado e compartilhado.' },
  { q: 'O curso cobre R134a e R1234yf?', a: 'Sim. O curso aborda ambos os fluidos refrigerantes, incluindo pressões de trabalho, procedimento de recarga por massa e legislação ambiental vigente.' },
  { q: 'Qual é a garantia?', a: 'Garantia incondicional de 15 dias. Se por qualquer motivo você não gostar, basta solicitar o reembolso e o valor é devolvido integralmente.' },
  { q: 'Como é feito o pagamento?', a: 'O pagamento é feito pela plataforma Kiwify, que aceita cartão de crédito em até 12 parcelas, boleto e Pix.' },
  { q: 'Terei suporte durante o curso?', a: 'Sim. O curso inclui 6 meses de suporte VIP via grupo no WhatsApp com o instrutor Giliard Mota, para tirar dúvidas técnicas ao longo do aprendizado.' },
];

const courseSchemaJsonLd = {
  '@type': 'Course',
  name: 'Curso de Ar Condicionado Automotivo Online',
  url: canonicalPageUrl,
  description: 'Curso completo de ar condicionado automotivo: diagnóstico, recarga de gás R134a e R1234yf, compressor, condensador, evaporador, eletricidade do sistema e gestão de serviços. +6.000 alunos formados.',
  inLanguage: 'pt-BR',
  courseMode: 'online',
  educationalLevel: 'beginner',
  timeRequired: 'PT100H',
  provider: {
    '@type': 'Organization',
    name: 'GL Treinamentos',
    url: 'https://gltreinamentos.com/',
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT100H',
    instructor: {
      '@type': 'Person',
      name: 'Giliard Mota',
      jobTitle: 'Especialista em Ar Condicionado Automotivo',
    },
  },
  offers: {
    '@type': 'Offer',
    price: '997.00',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    validFrom: '2026-01-01',
    url: canonicalPageUrl,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '312',
    bestRating: '5',
    worstRating: '1',
  },
  totalHistoricalEnrollment: 6000,
};

const faqPageJsonLd = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://cursodearcondicionado.com.br/' },
    { '@type': 'ListItem', position: 2, name: 'Curso de Ar Condicionado Automotivo', item: canonicalPageUrl },
  ],
};

const extraJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [courseSchemaJsonLd, faqPageJsonLd, breadcrumbJsonLd],
};
---

<BaseLayoutcursodear
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={[]}
  footerNav={beFootNav}
  contentThemeId="cursodear"
  canonicalOverride={canonicalPageUrl}
  extraJsonLd={extraJsonLd}
>
  <div class="bg-white text-slate-900">

    <!-- HERO -->
    <section class="relative min-h-[500px] overflow-hidden bg-slate-900">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-blue-950 opacity-95"></div>
      <div class="mx-auto max-w-4xl px-4 md:px-6 py-14 md:py-24 relative text-center">
        <span class="inline-block bg-blue-600 text-white text-xs font-bold px-4 py-1.5 rounded uppercase tracking-widest mb-5">
          +6.000 profissionais formados · GL Treinamentos
        </span>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-black text-white leading-tight">
          Curso de Ar Condicionado Automotivo Online
        </h1>
        <p class="text-gray-200 text-lg mt-5 max-w-2xl mx-auto leading-relaxed">
          Formação completa em diagnóstico, manutenção e recarga de sistemas A/C automotivos. Do zero ao avançado, com aulas práticas, suporte VIP e certificado.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 mt-6 text-white text-sm">
          <span class="text-yellow-400">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="font-bold">4.9</span>
          <span class="text-gray-300">(312 avaliações)</span>
          <span class="text-gray-400 hidden sm:inline">·</span>
          <span class="text-gray-300">+6.000 alunos</span>
          <span class="text-gray-400 hidden sm:inline">·</span>
          <span class="text-gray-300">100h de conteúdo</span>
        </div>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="#modulos"
            class="inline-flex items-center justify-center min-h-[52px] px-8 py-3 rounded-xl bg-white text-slate-900 text-base font-black hover:bg-gray-100 transition"
          >
            Ver o conteúdo do curso
          </a>
          <a
            href={kiwifyUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center min-h-[52px] px-8 py-3 rounded-xl bg-blue-600 text-white text-base font-black hover:bg-blue-500 transition"
          >
            Inscrever-se agora
          </a>
        </div>
      </div>
    </section>

    <!-- FICHA DO CURSO -->
    <section class="bg-slate-900 border-b border-slate-800">
      <div class="mx-auto max-w-5xl px-4 md:px-6 py-5">
        <ul class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-sm text-slate-300">
          <li class="flex items-center gap-2">
            <span class="text-blue-400 font-bold">100h</span>
            <span>carga horária</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-slate-600">·</span>
            <span>Online</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-slate-600">·</span>
            <span>Certificado incluso</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-slate-600">·</span>
            <span>Lives mensais</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-slate-600">·</span>
            <span>Iniciante ao avançado</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-slate-600">·</span>
            <span>Idioma: Português</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- INTRO SEO -->
    <section class="py-12 md:py-16 bg-white">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">Por que este curso é diferente</h2>

        <p class="text-slate-500 text-sm font-semibold uppercase tracking-widest mb-4">O problema com os cursos gratuitos</p>
        <p class="text-lg text-slate-700 leading-relaxed mb-5">
          Existem dezenas de cursos gratuitos de ar condicionado automotivo online. A maioria são apostilas em PDF com teoria básica.
          Servem para ter uma ideia do sistema. Não servem para atender um cliente com o carro parado na sua frente.
        </p>

        <p class="text-slate-500 text-sm font-semibold uppercase tracking-widest mb-4">O que este curso entrega</p>
        <p class="text-lg text-slate-700 leading-relaxed mb-5">
          São 100 horas de vídeo aula gravadas em oficina real, com diagnóstico passo a passo, leitura de manifold, recarga de gás R134a e R1234yf, elétrica do sistema e gestão de serviços.
          Do ciclo de refrigeração ao scanner automotivo, tudo demonstrado na prática.
        </p>

        <p class="text-slate-500 text-sm font-semibold uppercase tracking-widest mb-4">O resultado esperado</p>
        <p class="text-lg text-slate-700 leading-relaxed">
          Serviços de diagnóstico e recarga de gás chegam a R$ 600 por atendimento.
          Com 5 atendimentos por semana, já são mais de R$ 5.000 mensais de forma autônoma.
          O curso te dá o método para chegar lá.
        </p>
      </div>
    </section>

    <!-- O QUE VOCE VAI APRENDER -->
    <section class="py-12 md:py-16 bg-slate-50">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-8">O que você vai aprender</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {aprenderItems.map((item) => (
            <li class="flex items-start gap-3 bg-white rounded-lg p-4 border border-slate-200">
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold">&#10003;</span>
              <span class="text-slate-700 text-sm leading-snug">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- MODULOS -->
    <section id="modulos" class="py-12 md:py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-2">Conteúdo do curso</h2>
        <p class="text-slate-500 mb-8 text-sm">12 módulos · 100 horas de aulas práticas</p>
        <div class="space-y-3">
          {modulos.map((mod) => (
            <details class="group border border-slate-200 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none bg-slate-50 hover:bg-slate-100 transition">
                <div class="flex items-center gap-4">
                  <span class="text-xs font-bold text-slate-400 w-6 flex-shrink-0">{mod.number}</span>
                  <span class="font-bold text-slate-800 text-sm">{mod.title}</span>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <span class="text-xs text-slate-500 hidden sm:inline">{mod.count}</span>
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
              </summary>
              <div class="px-5 py-4 border-t border-slate-100 bg-white">
                <p class="text-slate-600 text-sm leading-relaxed">{mod.text}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- PARA QUEM E -->
    <section class="py-12 md:py-16 bg-blue-950 text-white">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black mb-8">Para quem é este curso</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-blue-900/60 rounded-xl p-6 border border-blue-800">
            <span class="inline-block bg-blue-700 text-blue-100 text-xs font-bold px-3 py-1 rounded uppercase tracking-widest mb-4">Iniciantes</span>
            <p class="text-blue-100 text-sm leading-relaxed mb-2">Você nunca trabalhou com A/C automotivo e quer entrar no mercado com uma base técnica sólida.</p>
            <p class="text-blue-300 text-sm leading-relaxed">O curso começa do zero e não exige conhecimento prévio em mecânica ou refrigeração.</p>
          </div>
          <div class="bg-blue-900/60 rounded-xl p-6 border border-blue-800">
            <span class="inline-block bg-blue-700 text-blue-100 text-xs font-bold px-3 py-1 rounded uppercase tracking-widest mb-4">Mecânicos e auxiliares</span>
            <p class="text-blue-100 text-sm leading-relaxed mb-2">Você já atua em oficina e quer adicionar o diagnóstico de A/C para aumentar o ticket médio dos atendimentos.</p>
            <p class="text-blue-300 text-sm leading-relaxed">Serviço de A/C agrega de R$ 250 a R$ 600 por atendimento sem precisar de estrutura extra.</p>
          </div>
          <div class="bg-blue-900/60 rounded-xl p-6 border border-blue-800">
            <span class="inline-block bg-blue-700 text-blue-100 text-xs font-bold px-3 py-1 rounded uppercase tracking-widest mb-4">Técnicos autônomos</span>
            <p class="text-blue-100 text-sm leading-relaxed mb-2">Você já faz serviços de A/C mas quer profissionalizar o diagnóstico e cobrar mais por atendimento.</p>
            <p class="text-blue-300 text-sm leading-relaxed">Diagnóstico correto reduz retorno de cliente e aumenta a margem em cada serviço.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- INSTRUTOR -->
    <section class="py-12 md:py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-8">Seu instrutor</h2>
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-shrink-0">
            <div class="w-28 h-28 rounded-full bg-blue-100 flex items-center justify-center text-5xl font-black text-blue-700">
              GM
            </div>
          </div>
          <div>
            <h3 class="text-xl font-black text-slate-900">Giliard Mota</h3>
            <p class="text-blue-600 font-semibold mb-3 text-sm">Especialista em Ar Condicionado Automotivo</p>
            <p class="text-slate-700 leading-relaxed mb-3">
              Mais de 25 anos de experiência prática em sistemas de A/C automotivo, trabalhando diretamente em oficina.
              Já formou mais de 6.000 profissionais pelo Brasil por meio de seus cursos online.
            </p>
            <p class="text-slate-700 leading-relaxed mb-4">
              Com mais de 100 mil inscritos no YouTube, é referência nacional em conteúdo técnico acessível, com didática voltada para quem está começando do zero.
            </p>
            <ul class="flex flex-wrap gap-3 text-sm">
              <li class="bg-slate-100 rounded-full px-4 py-1.5 text-slate-700">+25 anos de experiência</li>
              <li class="bg-slate-100 rounded-full px-4 py-1.5 text-slate-700">+6.000 alunos formados</li>
              <li class="bg-slate-100 rounded-full px-4 py-1.5 text-slate-700">+100k no YouTube</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- NUMEROS -->
    <section class="py-10 bg-blue-600 text-white">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-3xl md:text-4xl font-black">+6.000</div>
            <div class="text-blue-100 text-sm mt-1">Alunos formados</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-black">100h</div>
            <div class="text-blue-100 text-sm mt-1">De conteúdo prático</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-black">4.9</div>
            <div class="text-blue-100 text-sm mt-1">Avaliação média</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-black">+25 anos</div>
            <div class="text-blue-100 text-sm mt-1">Experiência do instrutor</div>
          </div>
        </div>
      </div>
    </section>

    <!-- BONUS -->
    <section class="py-12 md:py-16 bg-slate-50">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-2">Bônus inclusos na matrícula</h2>
        <p class="text-slate-500 mb-8 text-sm">Além das aulas, você recebe esses recursos para acelerar seu aprendizado e o início dos serviços</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl p-5 border border-slate-200">
            <h3 class="font-bold text-slate-800 mb-1 text-sm">Suporte VIP por 6 meses</h3>
            <p class="text-slate-500 text-xs leading-relaxed">Grupo exclusivo no WhatsApp com o instrutor e a equipe GL para tirar dúvidas técnicas direto de quem é do ofício.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-200">
            <h3 class="font-bold text-slate-800 mb-1 text-sm">App do curso</h3>
            <p class="text-slate-500 text-xs leading-relaxed">Acesse as aulas pelo celular a qualquer hora, mesmo em modo offline, sem precisar de computador.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-200">
            <h3 class="font-bold text-slate-800 mb-1 text-sm">Apostilas em PDF</h3>
            <p class="text-slate-500 text-xs leading-relaxed">Material de apoio para consultar na oficina, com tabelas de pressão, checklists e esquemas elétricos.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-200">
            <h3 class="font-bold text-slate-800 mb-1 text-sm">Lives mensais</h3>
            <p class="text-slate-500 text-xs leading-relaxed">Aulas ao vivo mensais com casos reais de diagnóstico, perguntas ao instrutor e atualização de conteúdo.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-200">
