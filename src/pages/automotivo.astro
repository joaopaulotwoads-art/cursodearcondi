---
import { getEntry } from 'astro:content';
import BaseLayoutcursodear from '../themes/cursodear/BaseLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const pageTitle = 'Curso de Ar Condicionado Automotivo Online | Do Zero ao Avançado 2026';
const pageDescription = 'Aprenda ar condicionado automotivo do zero: diagnóstico, recarga de gás, compressor e mais. +6.000 alunos formados. Certificado incluso.';
const pageKeywords = 'curso de ar condicionado automotivo online, curso ar condicionado automotivo, curso de refrigeração automotiva, curso diagnostico ar condicionado carro, curso tecnico ar condicionado automotivo';
const kiwifyUrl = 'https://pay.kiwify.com.br/4KQCJIS?afid=RCDE0GvN';
const canonicalPageUrl = 'https://cursodearcondicionado.com.br/automotivo/';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const beMenu = (await readSingleton('menu', 'cursodear')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'cursodear')) as Record<string, unknown> | null;
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);

const modulos = [
  { number: '01', title: 'Fundamentos do Ar Condicionado Automotivo', count: '12 aulas', text: 'Ciclo de refrigeração, componentes do sistema, tipos de fluidos refrigerantes, ferramentas obrigatórias e segurança no diagnóstico.' },
  { number: '02', title: 'Fluidos Refrigerantes: R134a e R1234yf', count: '8 aulas', text: 'Diferenças entre R134a e R1234yf, pressões de trabalho, legislação ambiental, recuperação e recarga correta por massa.' },
  { number: '03', title: 'Compressor Automotivo', count: '14 aulas', text: 'Tipos de compressor (pistão, scroll, rotativo), teste de compressão, embreagem magnética, diagnóstico de travamento e troca.' },
  { number: '04', title: 'Condensador e Evaporador', count: '10 aulas', text: 'Função de cada componente, inspeção de obstruções, limpeza química, identificação de vazamento e substituição.' },
  { number: '05', title: 'Válvula de Expansão e Tubo de Orifício', count: '8 aulas', text: 'Diferença entre TXV e tubo de orifício, sintomas de falha, teste com manifold e procedimento de troca.' },
  { number: '06', title: 'Secador e Filtro Desidrante', count: '5 aulas', text: 'Função do secador, quando substituir, posição correta e procedimento de instalação com vácuo.' },
  { number: '07', title: 'Eletricidade do Sistema A/C', count: '12 aulas', text: 'Relés, fusíveis, pressostato de alta e baixa, sensor de temperatura, fan motor e diagnóstico com multímetro.' },
  { number: '08', title: 'Diagnóstico com Scanner Automotivo', count: '8 aulas', text: 'Leitura de dados do módulo de A/C, PIDs de temperatura e pressão, códigos de falha e interpretação de sensores.' },
  { number: '09', title: 'Detecção e Vedação de Vazamentos', count: '6 aulas', text: 'Detector eletrônico de gás, UV com corante, localização de microvazamentos em mangueiras, conexões e evaporador.' },
  { number: '10', title: 'Manutenção Preventiva do Sistema', count: '7 aulas', text: 'Higienização do evaporador, troca de filtro de cabine, limpeza do condensador e checklist completo de revisão.' },
  { number: '11', title: 'Gestão e Precificação de Serviços', count: '5 aulas', text: 'Como precificar serviços de A/C, montagem de orçamento, gestão de estoque de peças e fidelização de clientes.' },
  { number: '12', title: 'Módulo Ganhe Rápido', count: '5 aulas', text: 'Os serviços de maior ticket e maior demanda para começar a faturar nos primeiros dias com o conhecimento do curso.' },
];

const faqItems = [
  { q: 'Qual a diferença deste curso para os cursos gratuitos de ar condicionado automotivo?', a: 'Os cursos gratuitos disponíveis online são apostilas em PDF com teoria introdutória. Servem para ter uma noção do sistema, mas não ensinam diagnóstico real. Este curso tem 100 horas de vídeo aula gravadas em oficina, com demonstração prática de cada procedimento.' },
  { q: 'O curso tem aulas em vídeo ou só material em PDF?', a: '100% em vídeo aula. Cada módulo é demonstrado na prática, com câmera no equipamento, leitura de manifold, diagnóstico elétrico e procedimentos reais de oficina. As apostilas em PDF são materiais de apoio.' },
  { q: 'O curso de ar condicionado automotivo é indicado para iniciantes?', a: 'Sim. O curso começa do zero, explicando o funcionamento do sistema antes de entrar em diagnóstico e manutenção. Não é necessário conhecimento prévio em mecânica ou refrigeração.' },
  { q: 'Quanto tempo tenho acesso ao curso?', a: 'O acesso é vitalício. Você assiste quantas vezes quiser, pelo celular ou computador, sem prazo de expiração.' },
  { q: 'O certificado do curso de ar condicionado automotivo é válido?', a: 'Sim. Ao concluir o curso você recebe o certificado de conclusão em formato digital, disponível para download e compartilhamento.' },
  { q: 'O curso cobre R134a e R1234yf?', a: 'Sim. O curso aborda ambos os fluidos refrigerantes, incluindo pressões de trabalho, procedimento de recarga por massa e legislação ambiental vigente.' },
  { q: 'Qual é a garantia do curso?', a: 'Garantia incondicional de 15 dias. Se por qualquer motivo você não gostar, basta solicitar o reembolso e o valor é devolvido integralmente.' },
  { q: 'Posso acessar o curso pelo celular?', a: 'Sim. O curso tem aplicativo próprio com acesso offline, permitindo assistir as aulas mesmo sem conexão com a internet.' },
  { q: 'Como é feito o pagamento?', a: 'O pagamento é feito pela plataforma Kiwify, que aceita cartão de crédito em até 12 parcelas, boleto e Pix.' },
];

const courseSchemaJsonLd = {
  '@type': 'Course',
  name: 'Curso de Ar Condicionado Automotivo Online',
  url: canonicalPageUrl,
  description: 'Curso completo de ar condicionado automotivo: diagnóstico, recarga de gás R134a e R1234yf, compressor, condensador, evaporador, eletricidade do sistema e gestão de serviços. +6.000 alunos formados.',
  inLanguage: 'pt-BR',
  courseMode: 'online',
  educationalLevel: 'beginner',
  timeRequired: 'PT100H',
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT100H',
    instructor: {
      '@type': 'Person',
      name: 'Giliard Mota',
      jobTitle: 'Especialista em Ar Condicionado Automotivo',
    },
  },
  offers: {
    '@type': 'Offer',
    price: '997.00',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    validFrom: '2026-01-01',
    url: canonicalPageUrl,
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '312',
    bestRating: '5',
    worstRating: '1',
  },
  totalHistoricalEnrollment: 6000,
};

const faqPageJsonLd = {
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://cursodearcondicionado.com.br/' },
    { '@type': 'ListItem', position: 2, name: 'Curso de Ar Condicionado Automotivo', item: canonicalPageUrl },
  ],
};

const extraJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [courseSchemaJsonLd, faqPageJsonLd, breadcrumbJsonLd],
};
---

<BaseLayoutcursodear
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={[]}
  footerNav={beFootNav}
  contentThemeId="cursodear"
  canonicalOverride={canonicalPageUrl}
  extraJsonLd={extraJsonLd}
>
  <div class="bg-white text-slate-900">

    <!-- CABECALHO DO CURSO -->
    <section
      class="relative overflow-hidden bg-slate-900"
      style="background-image: url('/images/automotivo-hero.webp'); background-size: cover; background-position: center;"
    >
      <div class="absolute inset-0 bg-black/70"></div>
      <div class="relative mx-auto max-w-4xl px-4 md:px-6 py-12 md:py-20">
        <nav class="text-xs text-slate-400 mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white transition">Início</a>
          <span class="mx-2">/</span>
          <span class="text-slate-300">Curso de Ar Condicionado Automotivo</span>
        </nav>
        <h1 class="text-3xl md:text-5xl font-black text-white leading-tight mb-4">
          Curso de Ar Condicionado Automotivo Online
        </h1>
        <p class="text-slate-300 text-lg max-w-2xl leading-relaxed mb-6">
          Formação completa em diagnóstico e manutenção de sistemas A/C automotivos. Do funcionamento básico ao diagnóstico com scanner, tudo em vídeo aula gravado em oficina real.
        </p>
        <div class="flex flex-wrap gap-4 text-sm text-slate-300 mb-8">
          <span class="flex items-center gap-1"><span class="text-yellow-400 font-bold">4.9</span> de avaliação</span>
          <span class="text-slate-600">·</span>
          <span>+6.000 alunos formados</span>
          <span class="text-slate-600">·</span>
          <span>100h de conteúdo</span>
          <span class="text-slate-600">·</span>
          <span>Certificado incluso</span>
        </div>
        <a
          href={kiwifyUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center min-h-[50px] px-8 py-3 rounded-xl bg-blue-600 text-white font-black hover:bg-blue-500 transition text-base"
        >
          Matricular-se no curso
        </a>
      </div>
    </section>

    <!-- SOBRE O CURSO -->
    <section class="py-12 md:py-16 bg-white border-b border-slate-100">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">
          Sobre o curso de ar condicionado automotivo online
        </h2>
        <p class="text-slate-700 leading-relaxed mb-4">
          O curso de ar condicionado automotivo online é uma formação completa voltada para quem quer aprender a diagnosticar, manter e reparar sistemas de A/C em veículos leves.
          O conteúdo vai do ciclo básico de refrigeração até o diagnóstico com scanner automotivo, cobrindo todos os componentes do sistema.
        </p>
        <p class="text-slate-700 leading-relaxed mb-4">
          Ao contrário dos cursos gratuitos disponíveis na internet — que em sua maioria são apostilas em PDF com teoria introdutória — este curso é ministrado em vídeo aula com câmera diretamente no equipamento.
          Cada procedimento é demonstrado na prática: leitura de manifold, teste de compressor, recarga de gás por massa, diagnóstico elétrico e muito mais.
        </p>
        <p class="text-slate-700 leading-relaxed">
          O curso tem 100 horas de conteúdo divididas em 12 módulos, com acesso vitalício pelo celular ou computador.
          Ao concluir, o aluno recebe certificado de conclusão em formato digital.
        </p>
      </div>
    </section>

    <!-- CONTEUDO PROGRAMATICO -->
    <section id="modulos" class="py-12 md:py-16 bg-slate-50 border-b border-slate-100">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-2">
          Conteúdo programático do curso de ar condicionado automotivo
        </h2>
        <p class="text-slate-500 mb-8 text-sm">12 módulos · 100 horas de aulas em vídeo · acesso vitalício</p>
        <div class="space-y-2">
          {modulos.map((mod) => (
            <details class="group border border-slate-200 rounded-xl overflow-hidden bg-white">
              <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none hover:bg-slate-50 transition">
                <div class="flex items-center gap-4">
                  <span class="text-xs font-bold text-slate-400 w-6 flex-shrink-0">{mod.number}</span>
                  <span class="font-semibold text-slate-800 text-sm">{mod.title}</span>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <span class="text-xs text-slate-400 hidden sm:inline">{mod.count}</span>
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
              </summary>
              <div class="px-5 py-4 border-t border-slate-100">
                <p class="text-slate-600 text-sm leading-relaxed">{mod.text}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- O QUE VOCE VAI APRENDER -->
    <section class="py-12 md:py-16 bg-white border-b border-slate-100">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-4">
          O que você vai aprender no curso de manutenção de ar condicionado automotivo
        </h2>
        <p class="text-slate-500 mb-8 text-sm">Habilidades práticas que você aplica diretamente na oficina</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {[
            'Identificar e testar todos os componentes do sistema A/C',
            'Realizar diagnóstico profissional com manifold',
            'Fazer recarga de gás R134a e R1234yf por massa',
            'Testar e substituir compressor automotivo',
            'Limpar e trocar condensador e evaporador',
            'Diagnosticar e reparar a válvula de expansão',
            'Ler e interpretar circuitos elétricos do sistema A/C',
            'Usar scanner automotivo para diagnóstico de falhas',
            'Localizar e vedar vazamentos de gás refrigerante',
            'Executar manutenção preventiva completa',
            'Precificar e orçar serviços de A/C automotivo',
            'Montar sua carteira de clientes e faturar de forma autônoma',
          ].map((item) => (
            <div class="flex items-start gap-3 p-4 border border-slate-200 rounded-lg">
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold">&#10003;</span>
              <span class="text-slate-700 text-sm leading-snug">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMO FUNCIONA -->
    <section class="py-12 md:py-16 bg-slate-50 border-b border-slate-100">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">
          Como funciona o curso de ar condicionado automotivo online
        </h2>
        <div class="space-y-6">
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white font-black text-sm flex items-center justify-center">1</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">Matrícula e acesso imediato</h3>
              <p class="text-slate-600 text-sm leading-relaxed">Após o pagamento, o acesso ao curso é liberado imediatamente pelo celular ou computador, sem precisar aguardar aprovação.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white font-black text-sm flex items-center justify-center">2</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">Aulas em vídeo gravadas em oficina</h3>
              <p class="text-slate-600 text-sm leading-relaxed">Cada módulo é filmado diretamente no equipamento real, com o instrutor demonstrando cada passo do diagnóstico e da manutenção.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white font-black text-sm flex items-center justify-center">3</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">Estude no seu ritmo</h3>
              <p class="text-slate-600 text-sm leading-relaxed">Sem horário fixo. Você assiste quantas aulas quiser por dia, pausa, volta e revisita qualquer módulo quantas vezes precisar.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white font-black text-sm flex items-center justify-center">4</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">Suporte para tirar dúvidas</h3>
              <p class="text-slate-600 text-sm leading-relaxed">Dúvidas técnicas surgem na prática. O curso inclui 6 meses de suporte via grupo no WhatsApp com o instrutor Giliard Mota.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white font-black text-sm flex items-center justify-center">5</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">Certificado ao concluir</h3>
              <p class="text-slate-600 text-sm leading-relaxed">Ao finalizar os módulos você solicita o certificado de conclusão em formato digital, disponível para download imediato.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PARA QUEM E -->
    <section class="py-12 md:py-16 bg-white border-b border-slate-100">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">
          Para quem é o curso de ar condicionado automotivo online
        </h2>
        <p class="text-slate-600 mb-8 leading-relaxed">
          O curso não exige conhecimento prévio em mecânica ou refrigeração. O conteúdo foi organizado para atender diferentes perfis:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="border border-slate-200 rounded-xl p-6">
            <h3 class="font-bold text-slate-900 mb-3">Iniciantes na área</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Quem nunca trabalhou com A/C automotivo e quer entrar no mercado com base técnica sólida, sem precisar de curso presencial caro.</p>
          </div>
          <div class="border border-slate-200 rounded-xl p-6">
            <h3 class="font-bold text-slate-900 mb-3">Mecânicos e auxiliares</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Profissionais de oficina que já fazem manutenção geral e querem adicionar o diagnóstico de A/C para aumentar o ticket médio dos atendimentos.</p>
          </div>
          <div class="border border-slate-200 rounded-xl p-6">
            <h3 class="font-bold text-slate-900 mb-3">Técnicos autônomos</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Quem já presta serviços de A/C e quer profissionalizar o diagnóstico, cobrar mais por atendimento e reduzir retornos por erro.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CARGA HORARIA -->
    <section class="py-12 md:py-16 bg-slate-50 border-b border-slate-100">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">
          Carga horária do curso de ar condicionado automotivo online
        </h2>
        <p class="text-slate-700 leading-relaxed mb-4">
          O curso tem <strong>100 horas de conteúdo</strong> organizadas em 12 módulos temáticos.
          A carga horária cobre desde os fundamentos do sistema até diagnóstico avançado, elétrica, gestão de serviços e o módulo de início rápido.
        </p>
        <p class="text-slate-700 leading-relaxed mb-4">
          Não existe prazo para conclusão. Você pode assistir no ritmo que preferir: algumas aulas por dia ou módulos completos no fim de semana.
          O acesso é vitalício — o curso não expira.
        </p>
        <p class="text-slate-700 leading-relaxed">
          O aplicativo do curso permite acesso offline: baixe as aulas pelo celular e assista sem precisar de conexão com a internet.
        </p>
      </div>
    </section>

    <!-- CERTIFICADO -->
    <section class="py-12 md:py-16 bg-white border-b border-slate-100">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-6">
          Certificado do curso de ar condicionado automotivo online
        </h2>
        <p class="text-slate-700 leading-relaxed mb-4">
          Ao concluir o curso você recebe o <strong>certificado de conclusão em formato digital</strong>, disponível para download imediato pela plataforma.
          O certificado pode ser compartilhado em redes sociais, enviado para clientes ou apresentado em processos seletivos.
        </p>
        <p class="text-slate-700 leading-relaxed mb-4">
          O certificado comprova a formação em diagnóstico e manutenção de sistemas de ar condicionado automotivo, com carga horária de 100 horas.
        </p>
        <p class="text-slate-700 leading-relaxed">
          Para técnicos autônomos, apresentar o certificado para clientes transmite credibilidade e justifica a cobrança de um valor mais alto pelos serviços.
        </p>
      </div>
    </section>

    <!-- INSTRUTOR -->
    <section class="py-12 md:py-16 bg-slate-50 border-b border-slate-100">
      <div class="mx-auto max-w-4xl px-4 md:px-6">
        <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-8">
          Instrutor do curso de ar condicionado automotivo
        </h2>
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-shrink-0">
            <img
              src="/images/giliard-mota.webp"
              alt="Giliard Mota, instrutor do curso de ar condicionado automotivo online"
              class="w-28 h-28 rounded-full object-cover border-4 border-white shadow"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div>
            <h3 class="text-xl font-black text-slate-900">Giliard Mota</h3>
            <p class="text-blue-600 font-semibold mb-4 text-sm">Especialista em Ar Condicionado Automotivo</p>
            <p class="text-slate-700 leading-relaxed mb-3">
              Giliard Mota tem mais de 25 anos de experiência prática em sistemas de A/C automotivo, trabalhando diretamente em oficina com veículos leves e pesados.
            </p>
            <p class="text-slate-700 leading-relaxed mb-4">
              Com mais de 100 mil inscritos no YouTube, é referência nacional em conteúdo técnico de refrigeração automotiva, com didática voltada para quem está começando do zero e para quem quer aprofundar o diagnóstico.
            </p>
            <div class="flex flex-wrap gap-3 text-sm">
              <span class="bg-slate-100 rounded-full px-4 py-1.5 text-slate-700">+25 anos de experiência</span>
