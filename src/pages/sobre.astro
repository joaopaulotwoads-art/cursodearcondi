---
import { getEntry } from 'astro:content';
import BaseLayoutcursodear from '../themes/cursodear/BaseLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import { footerNavFromSingleton, logoSrcFromMenu, navFromMenu } from '../utils/theme-nav';
import { resolvePublicSiteUrl } from '../utils/read-site-settings';

const pageTitle = 'Quem Somos | Formação Técnica Profissional em Climatização';
const pageDescription =
  'Conheça nossa plataforma de formação técnica profissional. Instrutores especialistas, certificado reconhecido e +11.900 alunos formados.';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteName = settings?.data?.siteName || 'Curso de Ar Condicionado';
const siteUrl = resolvePublicSiteUrl(settings?.data?.canonicalUrl as string | undefined, Astro.url.origin);

const beMenu = (await readSingleton('menu', 'cursodear')) as Record<string, unknown> | null;
const beFoot = (await readSingleton('footer', 'cursodear')) as Record<string, unknown> | null;
const beNav = beMenu ? navFromMenu(beMenu) : [];
const beFootNav = beFoot ? footerNavFromSingleton(beFoot) : [];
const logoForLayout = logoSrcFromMenu(beMenu) || '/images/cursodear/logo.png';
const siteNameForLayout = String((beMenu?.logoText as string | undefined)?.trim() || siteName);

const aboutSchemaJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Curso de Ar Condicionado',
  description:
    'Plataforma de cursos profissionalizantes técnicos em refrigeração, climatização e manutenção de eletrodomésticos.',
  url: 'https://cursodearcondicionado.com.br',
  email: 'contato@cursodearcondicionado.com.br',
  telephone: '+55-14-98803-4123',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Rodrigues Alves, 96',
    addressLocality: 'Bauru',
    addressRegion: 'SP',
    addressCountry: 'BR',
    postalCode: '17040-000',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -22.313512279677077,
    longitude: -49.03531582470722,
  },
  hasMap: 'https://maps.app.goo.gl/bAPz55ZAM24twfTo9',
  sameAs: [
    'https://instagram.com/cursodear',
    'https://youtube.com/@cursodear',
    'https://facebook.com/cursodear',
  ],
  founder: {
    '@type': 'Person',
    name: 'Leandro Moraes',
    jobTitle: 'Instrutor e Especialista em Refrigeração',
    knowsAbout: [
      'Ar Condicionado',
      'Refrigeração',
      'Climatização',
      'Manutenção de Eletrodomésticos',
      'Tecnologia Inverter',
    ],
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Cursos Profissionalizantes',
    itemListElement: [
      {
        '@type': 'Course',
        name: 'Curso de Ar Condicionado',
        url: 'https://cursodearcondicionado.com.br/',
        provider: {
          '@type': 'Organization',
          name: 'Curso de Ar Condicionado',
        },
      },
    ],
  },
};
---

<BaseLayoutcursodear
  title={pageTitle}
  description={pageDescription}
  siteName={siteNameForLayout}
  logoSrc={logoForLayout}
  siteUrl={siteUrl}
  nav={beNav}
  footerNav={beFootNav}
  contentThemeId="cursodear"
  extraJsonLd={aboutSchemaJsonLd}
  canonicalOverride="https://cursodearcondicionado.com.br/sobre"
>
  <div class="bg-white text-slate-900">
    <section class="bg-slate-800 py-16 text-center text-white">
      <div class="mx-auto max-w-4xl px-6">
        <span class="text-orange-500 font-bold text-xs uppercase tracking-widest">
          CURSO DE AR CONDICIONADO
        </span>
        <h1 class="text-4xl font-black text-white mt-2 mb-4">
          Sobre o Curso de Ar Condicionado
        </h1>
        <p class="text-gray-300 max-w-2xl mx-auto text-base leading-relaxed">
          Plataforma de cursos profissionalizantes focada em
          formação técnica prática para o mercado de refrigeração,
          climatização e manutenção de eletrodomésticos.
        </p>
      </div>
    </section>

    <section class="bg-white">
      <div class="max-w-4xl mx-auto px-6 py-16">
        <h2 class="text-3xl font-black text-slate-800 mb-6">Quem Somos</h2>
        <div class="space-y-4 text-gray-600 text-base leading-relaxed">
          <p>
            O Curso de Ar Condicionado é uma plataforma digital de cursos
            profissionalizantes criada para democratizar o acesso
            à formação técnica de qualidade no Brasil. Nosso foco
            é o mercado de refrigeração, climatização e manutenção
            de eletrodomésticos — um setor em constante crescimento
            e com alta demanda por profissionais qualificados.
          </p>
          <p>
            Trabalhamos com instrutores especialistas e ativos no
            mercado, garantindo que cada aula reflita a realidade
            do dia a dia do técnico profissional. Nossos cursos
            são 100% online, com acesso vitalício, certificado
            reconhecido e suporte dedicado ao aluno.
          </p>
          <p>
            Desde o início da nossa operação, já contribuímos
            para a formação de mais de 11.900 profissionais
            em todo o Brasil — do Norte ao Sul do país —
            que hoje atuam como técnicos autônomos, prestadores
            de serviço e empreendedores do setor.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-slate-800 py-16">
      <div class="mx-auto grid max-w-5xl grid-cols-2 md:grid-cols-4">
        <article class="text-center px-6 py-8 border-r border-slate-700">
          <p class="text-4xl font-black text-orange-500">+11.900</p>
          <p class="text-gray-400 text-sm uppercase tracking-wider mt-1">Alunos Formados</p>
        </article>
        <article class="text-center px-6 py-8 border-r border-slate-700">
          <p class="text-4xl font-black text-orange-500">5+</p>
          <p class="text-gray-400 text-sm uppercase tracking-wider mt-1">Cursos Disponíveis</p>
        </article>
        <article class="text-center px-6 py-8 border-r border-slate-700">
          <p class="text-4xl font-black text-orange-500">94%</p>
          <p class="text-gray-400 text-sm uppercase tracking-wider mt-1">Avaliações Positivas</p>
        </article>
        <article class="text-center px-6 py-8">
          <p class="text-4xl font-black text-orange-500">4.7★</p>
          <p class="text-gray-400 text-sm uppercase tracking-wider mt-1">Nota Média dos Cursos</p>
        </article>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-4xl mb-4">🎯</div>
            <h3 class="font-black text-slate-800 text-lg mb-3">Nossa Missão</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Democratizar o acesso à formação técnica
              de qualidade, capacitando profissionais para
              conquistar independência financeira através
              de um ofício valorizado.
            </p>
          </article>
          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-4xl mb-4">🔭</div>
            <h3 class="font-black text-slate-800 text-lg mb-3">Nossa Visão</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Ser a principal plataforma de cursos
              técnicos profissionalizantes do Brasil,
              reconhecida pela qualidade do conteúdo e
              pelo resultado gerado aos alunos.
            </p>
          </article>
          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-4xl mb-4">💡</div>
            <h3 class="font-black text-slate-800 text-lg mb-3">Nossos Valores</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Praticidade, transparência, resultado
              real, suporte humano e compromisso com a
              evolução profissional de cada aluno.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <span class="text-orange-500 font-bold text-xs uppercase tracking-widest">
          CURSO DE AR CONDICIONADO
        </span>

        <h2 class="text-3xl font-black text-slate-800 mt-2 mb-4">
          Por que estudar com a gente?
        </h2>

        <p class="text-gray-500 max-w-2xl mx-auto text-base leading-relaxed mb-12">
          Todos os cursos do Curso de Ar Condicionado são ministrados
          por profissionais ativos no mercado, com anos de
          experiência prática e didática comprovada.
          Você aprende com quem realmente faz.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 text-center">
            <div class="text-4xl mb-4">👷</div>
            <h3 class="font-bold text-slate-800 text-base mb-2">
              Experiência Real
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Instrutores com anos de atuação no campo,
              não apenas teoria.
            </p>
          </div>

          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 text-center">
            <div class="text-4xl mb-4">🎓</div>
            <h3 class="font-bold text-slate-800 text-base mb-2">
              Didática Comprovada
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Método validado por mais de 11.900 alunos
              formados em todo o Brasil.
            </p>
          </div>

          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 text-center">
            <div class="text-4xl mb-4">🛠️</div>
            <h3 class="font-bold text-slate-800 text-base mb-2">
              Foco no Mercado
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Conteúdo atualizado com o que o mercado
              exige hoje do profissional técnico.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center">
          <h2 class="text-3xl font-black text-slate-800">Informações de Contato</h2>
          <p class="mt-2 text-gray-500">Entre em contato ou nos acompanhe nas redes sociais</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-orange-500 text-3xl">📍</div>
            <h3 class="mt-3 font-black text-slate-800">Localização</h3>
            <p class="mt-3 text-sm text-gray-600 leading-relaxed">
              Curso de Ar Condicionado
              <br />
              Av. Rodrigues Alves, 96
              <br />
              Jardim Redentor — Bauru/SP
            </p>
            <a
              href="https://maps.app.goo.gl/bAPz55ZAM24twfTo9"
              target="_blank"
              rel="noopener noreferrer"
              class="text-orange-500 text-xs hover:underline mt-2 inline-block"
            >
              Ver no Google Maps →
            </a>
          </article>

          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-orange-500 text-3xl">📞</div>
            <h3 class="mt-3 font-black text-slate-800">Contato</h3>
            <div class="mt-3 text-sm text-gray-600 leading-relaxed space-y-1">
              <p>
                WhatsApp:
                <a href="https://wa.me/5514988034123" target="_blank" rel="noopener noreferrer" class="text-orange-500 hover:underline">
                  (14) 98803-4123
                </a>
              </p>
              <p>E-mail: contato@cursodearcondicionado.com.br</p>
              <p>Atendimento: Seg a Sex, 9h às 18h</p>
            </div>
          </article>

          <article class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center">
            <div class="text-orange-500 text-3xl">📱</div>
            <h3 class="mt-3 font-black text-slate-800">Redes Sociais</h3>
            <div class="mt-3">
              <a
                href="https://instagram.com/cursodear"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-gray-600 hover:text-orange-500 transition text-sm py-1 justify-center"
              >
                📸 @cursodear (Instagram)
              </a>
              <a
                href="https://youtube.com/@cursodear"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-gray-600 hover:text-orange-500 transition text-sm py-1 justify-center"
              >
                ▶️ Curso de Ar Condicionado (YouTube)
              </a>
              <a
                href="https://facebook.com/cursodear"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-gray-600 hover:text-orange-500 transition text-sm py-1 justify-center"
              >
                👍 Curso de Ar Condicionado (Facebook)
              </a>
            </div>
          </article>
        </div>
        <div class="mt-12 rounded-2xl overflow-hidden shadow-md border border-gray-200 max-w-4xl mx-auto">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.0615387622606!2d-49.03531582470722!3d-22.313512279677077!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94bf5d70916f0c85%3A0xf9fafa89cf77ec46!2sAv.%20Rodrigues%20Alves%2C%2096%20-%20Jardim%20Redentor%2C%20Bauru%20-%20SP!5e0!3m2!1spt-PT!2sbr!4v1777417609252!5m2!1spt-PT!2sbr"
            width="100%"
            height="350"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>

    <section class="bg-orange-500 py-16 text-center">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-white text-3xl font-black">Pronto para começar sua formação?</h2>
        <p class="text-orange-100 mt-3">Escolha seu curso e comece hoje mesmo.</p>
        <a
          href="/cursos"
          class="bg-white text-orange-500 font-black py-4 px-10 rounded-xl text-lg uppercase hover:bg-orange-50 transition inline-flex mt-8"
        >
          VER TODOS OS CURSOS
        </a>
      </div>
    </section>
  </div>
</BaseLayoutcursodear>
