---
/**
 * admin/pages/about.astro
 *
 * PĂĄgina de ediĂ§ĂŁo do Sobre (singleton).
 * No Modo Local: local/about.yaml. Modo Blog: activeTheme (classic, cursodear, âŚ).
 */

import { getEntry } from 'astro:content';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AboutEditor from '../../../components/admin/AboutEditor.tsx';
import SingletonEditor from '../../../components/admin/SingletonEditor.tsx';
import { cursodear_ABOUT_FIELDS } from '../../../components/admin/cursodear-editor-fields';
import { readSingleton } from '../../../utils/singleton-utils';
import { getEffectiveSiteMode } from '../../../utils/admin-site-mode';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode = getEffectiveSiteMode(Astro.cookies, settings);
const isLocal = siteMode === 'local';
const activeBlogTheme = (settings?.data?.activeTheme || 'classic') as string;

const themeId = isLocal ? 'local' : activeBlogTheme;
let initialData = await readSingleton('about', themeId);

if (isLocal && !initialData) {
    const localHome = await readSingleton('home', 'local') || {};
    initialData = {
        heroTitle: localHome.aboutTitle || 'Quem Somos',
        heroSubtitle: localHome.aboutSubtitle || '',
        aboutImage: localHome.aboutImage || null,
        aboutText: localHome.aboutText || '',
        aboutStats: localHome.aboutStats || [],
        missionTitle: 'Nossa MissĂŁo',
        missionDescription: localHome.aboutText || '',
        visionTitle: 'Nossa VisĂŁo',
        visionDescription: 'Ser referĂŞncia em atendimento na nossa regiĂŁo.',
        values: localHome.aboutValues || [
            { icon: 'â­', title: 'Qualidade', description: 'ServiĂ§os executados com excelĂŞncia.' },
            { icon: 'âąď¸', title: 'Pontualidade', description: 'Compromisso com prazos.' },
            { icon: 'đŹ', title: 'TransparĂŞncia', description: 'OrĂ§amento claro e sem surpresas.' },
            { icon: 'đĄď¸', title: 'Garantia', description: 'Trabalho com garantia.' },
        ],
        valuesTitle: 'Nossos Valores',
        differentialsTitle: 'Por que nos escolher?',
        differentials: localHome.aboutDifferentials || [
            'Profissionais qualificados e certificados',
            'OrĂ§amento sem compromisso',
            'Atendimento rĂĄpido na sua regiĂŁo',
            'Materiais de qualidade',
            'Garantia em todos os serviĂ§os',
        ],
        ctaTitle: localHome.ctaTitle || 'Precisa de ajuda agora?',
        ctaDescription: localHome.ctaText || '',
        ctaButtonText: localHome.ctaButtonText || 'Chamar no WhatsApp',
    };
}
---

<AdminLayout title="Sobre NĂłs - CNX Agency Admin">
    <div id="about-editor-wrapper" class="min-h-[400px]">
        {!isLocal && activeBlogTheme === 'cursodear' ? (
            <SingletonEditor
                client:only="react"
                name="about"
                title="Sobre (tema Curso de Ar CondicionadoŁe)"
                fields={cursodear_ABOUT_FIELDS}
                initialData={initialData ?? {}}
                themeId="cursodear"
            />
        ) : (
            <AboutEditor
                client:only="react"
                initialData={initialData}
                themeId={themeId}
            />
        )}
    </div>
    <noscript>
        <div class="p-8 text-center">
            <p class="text-[#a3a3a3] mb-4">JavaScript ĂŠ necessĂĄrio para editar pĂĄginas.</p>
        </div>
    </noscript>
</AdminLayout>
