---
/**
 * admin/pages/home.astro
 *
 * EdiĂ§ĂŁo da Home: tema classic â†’ HomeEditor; tema cursodear â†’ SingletonEditor (campos Curso de Ar CondicionadoŁe).
 */

import { getEntry } from 'astro:content';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import HomeEditor from '../../../components/admin/HomeEditor.tsx';
import SingletonEditor from '../../../components/admin/SingletonEditor.tsx';
import { cursodear_HOME_FIELDS } from '../../../components/admin/cursodear-editor-fields';
import { readSingleton } from '../../../utils/singleton-utils';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const activeThemeId = (settings?.data?.activeTheme || 'classic') as string;
const initialData = await readSingleton('home', activeThemeId);
---

<AdminLayout title="PĂˇgina Inicial - Admin">
    <div id="home-editor-wrapper" class="min-h-[400px]">
        {activeThemeId === 'cursodear' ? (
            <SingletonEditor
                client:only="react"
                name="home"
                title="PĂˇgina inicial (tema Curso de Ar CondicionadoŁe)"
                fields={cursodear_HOME_FIELDS}
                initialData={initialData ?? {}}
                themeId="cursodear"
            />
        ) : initialData !== null ? (
            <HomeEditor client:only="react" initialData={initialData} />
        ) : (
            <div class="p-8 text-center">
                <p class="text-[#a3a3a3] mb-4">Carregando dados da pĂˇgina inicial...</p>
                <p class="text-[#737373] text-sm">Verifique se home.yaml existe em src/content/singletons/{activeThemeId}/.</p>
            </div>
        )}
    </div>
    <noscript>
        <div class="p-8 text-center">
            <p class="text-[#a3a3a3] mb-4">JavaScript Ă© necessĂˇrio para editar pĂˇginas.</p>
        </div>
    </noscript>
</AdminLayout>
